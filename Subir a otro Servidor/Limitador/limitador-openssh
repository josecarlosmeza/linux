#!/bin/bash
echo "--- 🛠️  INSTALACIÓN DEL LIMITADOR OPENSSH (VERSIÓN SEGURA) ---"
echo ""

# --- CONFIGURACIÓN DE RUTAS ---
LIMITER_PATH="/usr/bin/check_ssh_limits.sh"
DB_SOURCE="/root/usuarios.db"
PAM_SSHD_FILE="/etc/pam.d/sshd"

# --- 1. CREAR ARCHIVO DE LÍMITES (Si no existe) ---
echo "--- 1. Configurando base de datos de usuarios: $DB_SOURCE ---"
if [ ! -f "$DB_SOURCE" ]; then
    sudo tee "$DB_SOURCE" > /dev/null <<EOF
# USUARIO LIMITE
* 3
REDLIBRE 10
EOF
    echo "✅ Archivo de límites creado."
else
    echo "✅ El archivo de límites ya existe."
fi
chmod 644 "$DB_SOURCE"

# --- 2. CREAR SCRIPT LIMITADOR CON EXCEPCIÓN PARA ROOT ---
echo "--- 2. Creando Script Limitador en $LIMITER_PATH ---"
sudo tee "$LIMITER_PATH" > /dev/null <<'EOF_LIMITER'
#!/bin/bash
# Script de límite ejecutado por PAM
DB_SOURCE="/root/usuarios.db"
USER="$PAM_USER"

# 1. EXCEPCIÓN TOTAL PARA ROOT (Seguridad ante bloqueos)
if [ "$USER" == "root" ] || [ -z "$USER" ]; then
    exit 0
fi

# 2. OBTENER LÍMITE DEL ARCHIVO
# Intenta buscar el usuario, si no, busca el global (*), si no, usa 3 por defecto.
MAX_ALLOWED=$(grep "^$USER " "$DB_SOURCE" 2>/dev/null | awk '{print $2}')
if [ -z "$MAX_ALLOWED" ]; then
    MAX_ALLOWED=$(grep "^\* " "$DB_SOURCE" 2>/dev/null | awk '{print $2}')
fi
MAX_ALLOWED=${MAX_ALLOWED:-3}

# 3. CONTAR SESIONES SSH del usuario (alineado con infousers: ps; incluye sshd-session en distros nuevas)
CURRENT_SESSIONS=$(ps -u "$USER" 2>/dev/null | grep -c '[s]shd' || true)
CURRENT_SESSIONS=${CURRENT_SESSIONS:-0}

# 4. APLICAR LÓGICA DE BLOQUEO (-gt: la sesión que entra suele ya figurar en ps al ejecutarse PAM)
if [ "$CURRENT_SESSIONS" -gt "$MAX_ALLOWED" ]; then
    logger -t ssh_limiter "DENIED: $USER excedió el límite de $MAX_ALLOWED (Activas: $CURRENT_SESSIONS)"
    exit 1
fi

# 5. SIEMPRE PERMITIR POR DEFECTO SI NADA DE LO ANTERIOR FALLÓ
exit 0
EOF_LIMITER

sudo chmod +x "$LIMITER_PATH"
echo "✅ Script limitador instalado con protección para root."

# --- 3. CONFIGURAR PAM ---
echo "--- 3. Configurando PAM ($PAM_SSHD_FILE) ---"
# Limpiar instalaciones previas
sudo sed -i "/$LIMITER_PATH/d" "$PAM_SSHD_FILE"

# Debian/Ubuntu: no hay pam_unix.so en sshd (usa @include common-account). Alma/RHEL: password-auth o pam_unix.
PAM_LINE="account    required    pam_exec.so $LIMITER_PATH"
if grep -qE '^@include[[:space:]]+common-account' "$PAM_SSHD_FILE" 2>/dev/null; then
    sudo sed -i "/^@include[[:space:]]\+common-account/i ${PAM_LINE}" "$PAM_SSHD_FILE"
    echo "✅ pam_exec insertado antes de @include common-account (Debian/Ubuntu)."
elif grep -qE '^account[[:space:]]+include[[:space:]]+password-auth' "$PAM_SSHD_FILE" 2>/dev/null; then
    sudo sed -i "/^account[[:space:]]\+include[[:space:]]\+password-auth/i ${PAM_LINE}" "$PAM_SSHD_FILE"
    echo "✅ pam_exec insertado antes de account include password-auth (RHEL/Alma)."
elif grep -qE '^account[[:space:]]+required[[:space:]]+pam_unix\.so' "$PAM_SSHD_FILE" 2>/dev/null; then
    sudo sed -i "/^account[[:space:]]\+required[[:space:]]\+pam_unix\.so/i ${PAM_LINE}" "$PAM_SSHD_FILE"
    echo "✅ pam_exec insertado antes de pam_unix.so."
else
    echo "⚠️  No se encontró ancla típica en $PAM_SSHD_FILE. Añada a mano esta línea en la pila account, antes de permitir la cuenta:"
    echo "    $PAM_LINE"
fi

if ! grep -qF "pam_exec.so $LIMITER_PATH" "$PAM_SSHD_FILE" 2>/dev/null; then
    echo "⚠️  Revise /etc/pam.d/sshd: sin pam_exec el limitador PAM no se ejecuta."
fi
if grep -qE '^\s*UsePAM\s+no' /etc/ssh/sshd_config 2>/dev/null; then
    echo "⚠️  sshd tiene UsePAM no — el limitador PAM no se ejecutará hasta UsePAM yes y reinicio de ssh."
fi

# --- 4. REINICIAR SERVICIOS ---
echo "--- 4. Reiniciando OpenSSH ---"
if sudo systemctl restart sshd 2>/dev/null; then
    echo "✅ Servicio sshd reiniciado."
elif sudo systemctl restart ssh 2>/dev/null; then
    echo "✅ Servicio ssh reiniciado (Debian/Ubuntu)."
else
    echo "⚠️  No se pudo reiniciar sshd/ssh con systemctl; ejecute: systemctl restart ssh o sshd"
fi
echo "✅ Instalación del script y PAM finalizada."
echo ""
echo "⚠️  NOTA: El usuario 'root' ahora tiene acceso total garantizado."
