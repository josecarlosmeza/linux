#!/bin/bash
# Cambiar fecha de vencimiento por nombre de usuario (sin listar todos).
# VersiГіn simplificada de mudardata + resumen puntual tipo infousers (un solo usuario).
#====================================================
if [[ $EUID -ne 0 ]]; then
    echo -e "\033[1;31mEjecute como root.\033[0m"
    exit 1
fi

DB_FILE="/root/usuarios.db"
[[ -f "$HOME/usuarios.db" && ! -f "$DB_FILE" ]] && DB_FILE="$HOME/usuarios.db"

clear
tput setaf 7
tput setab 4
tput bold
printf '%33s%s%-12s\n' "Vencimiento por usuario"
tput sgr0
echo ""
echo -e "\033[1;33mIndique el usuario cuya fecha de vencimiento desea cambiar.\033[0m"
echo -e "\033[1;37mFormato: \033[1;32mnombre\033[1;37m o \033[1;32musuario:contraseГ±a\033[1;37m (cГіdigo de acceso al crear).\033[0m"
echo -e "\033[1;37m(Sin listado masivo; cuentas locales UID в‰Ґ 1000, excepto nobody.)\033[0m"
echo ""
echo -ne "\033[1;32mUsuario o usuario:contraseГ±a:\033[1;37m "
read -r entrada

entrada="${entrada//$'\r'/}"
entrada="${entrada#"${entrada%%[![:space:]]*}"}"
entrada="${entrada%"${entrada##*[![:space:]]}"}"

if [[ -z "$entrada" ]]; then
    echo -e "\n\033[1;31mEntrada vacГ­a.\033[0m\n"
    exit 1
fi

_senha_input=""
if [[ "$entrada" == *:* ]]; then
    usuario="${entrada%%:*}"
    _senha_input="${entrada#*:}"
    usuario="${usuario#"${usuario%%[![:space:]]*}"}"
    usuario="${usuario%"${usuario##*[![:space:]]}"}"
    _senha_input="${_senha_input#"${_senha_input%%[![:space:]]*}"}"
    _senha_input="${_senha_input%"${_senha_input##*[![:space:]]}"}"
    if [[ -z "$usuario" ]]; then
        echo -e "\n\033[1;31mFormato invГЎlido: falta el nombre de usuario antes de В«:В».\033[0m\n"
        exit 1
    fi
else
    usuario="$entrada"
fi

if ! id "$usuario" &>/dev/null; then
    echo -e "\n\033[1;41m El usuario '$usuario' no existe. \033[0m\n"
    exit 1
fi

_uid=$(id -u "$usuario" 2>/dev/null) || _uid=0
if [[ "$_uid" -lt 1000 ]] || [[ "$usuario" == "nobody" ]]; then
    echo -e "\n\033[1;31mSolo se permiten cuentas de usuario habituales (UID в‰Ґ 1000).\033[0m\n"
    exit 1
fi

if [[ -n "$_senha_input" ]]; then
    if [[ -e "/etc/RedLibre/senha/$usuario" ]]; then
        _senha_real=$(cat "/etc/RedLibre/senha/$usuario")
        if [[ "$_senha_input" != "$_senha_real" ]]; then
            echo -e "\n\033[1;31mLa contraseГ±a indicada no coincide con la del usuario '$usuario'.\033[0m\n"
            exit 1
        fi
    fi
fi

# --- Resumen breve (equivalente compacto a infousers + cabecera de mudardata) ---
[[ -f /etc/RedLibre/redlibre-vence-common ]] && . /etc/RedLibre/redlibre-vence-common
[[ $(grep -cw "$usuario" "$DB_FILE" 2>/dev/null) == "1" ]] && lim=$(grep -w "$usuario" "$DB_FILE" | cut -d' ' -f2) || lim="1"
[[ -e "/etc/RedLibre/senha/$usuario" ]] && senha=$(cat "/etc/RedLibre/senha/$usuario") || senha="вЂ”"
conexiones=$(ps -u "$usuario" 2>/dev/null | grep -c sshd || true)
_vraw=""
declare -F redlibre_vence_get >/dev/null 2>&1 && _vraw=$(redlibre_vence_get "$usuario" 2>/dev/null) || true
if [[ -n "$_vraw" ]]; then
    expire_raw="$_vraw"
else
    expire_raw=$(LANG=en_US.UTF-8 chage -l "$usuario" 2>/dev/null | grep "Account expires" | awk -F': ' '{print $2}' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
fi

echo ""
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
echo -e "\033[1;33m  Resumen вЂ” \033[1;32m$usuario\033[0m"
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
echo -e "\033[1;32m  LГ­mite conexiones (BD): \033[1;37m$lim\033[0m"
echo -e "\033[1;32m  ContraseГ±a (panel):     \033[1;37m$senha\033[0m"
echo -e "\033[1;32m  Sesiones SSH activas:   \033[1;37m$conexiones\033[0m"
if [[ -z "$expire_raw" || "$expire_raw" == "never" ]]; then
    echo -e "\033[1;32m  Vencimiento:            \033[1;33mSin fecha (nunca)\033[0m"
    echo -e "\033[1;32m  Estado:                 \033[1;32mVГЃLIDO\033[0m"
else
    if [[ -n "$_vraw" ]]; then
        fecha_venc=$(date --date="$expire_raw" '+%d/%m/%Y %H:%M' 2>/dev/null || date -d "$expire_raw" '+%d/%m/%Y %H:%M' 2>/dev/null)
    else
        fecha_venc=$(date --date="$expire_raw" '+%d/%m/%Y' 2>/dev/null || date -d "$expire_raw" '+%d/%m/%Y' 2>/dev/null)
    fi
    exp_sec=$(date +%s --date="$expire_raw" 2>/dev/null || date +%s -d "$expire_raw" 2>/dev/null)
    now_sec=$(date +%s)
    echo -e "\033[1;32m  Vencimiento:            \033[1;37m${fecha_venc:-$expire_raw}\033[0m"
    if [[ -n "$_vraw" ]]; then
        echo -e "\033[1;32m  Hora de corte (aprox):  \033[1;37m$(date --date="$expire_raw" '+%H:%M' 2>/dev/null || date -d "$expire_raw" '+%H:%M' 2>/dev/null) (В±2 min)\033[0m"
    fi
    if [[ -n "$exp_sec" ]]; then
        if [[ $now_sec -ge $exp_sec ]]; then
            echo -e "\033[1;32m  Estado:                 \033[1;31mEXPIRADO\033[0m"
        else
            dias_rest=$(( (exp_sec - now_sec) / 86400 ))
            echo -e "\033[1;32m  DГ­as restantes:         \033[1;37m$dias_rest\033[0m"
            echo -e "\033[1;32m  Estado:                 \033[1;32mVГЃLIDO\033[0m"
        fi
    fi
fi
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
echo ""
echo -e "\033[1;31mCONFIGURACIГ“N DE TIEMPO:\033[0m"
echo -e "\033[1;32mEjemplos: \033[1;37m'30' (dГ­as) o '21/12/2025' (fecha especГ­fica)\033[0m"
echo ""
echo -ne "\033[1;32mNueva fecha para \033[1;33m$usuario: \033[1;37m"
read -r inputdate

inputdate="${inputdate//$'\r'/}"
inputdate="${inputdate#"${inputdate%%[![:space:]]*}"}"
inputdate="${inputdate%"${inputdate##*[![:space:]]}"}"

[[ -f /etc/RedLibre/redlibre-vence-common ]] && . /etc/RedLibre/redlibre-vence-common

_vence_line=""
gui_hora=""
if [[ $inputdate =~ ^[0-9]+$ ]]; then
    if declare -F redlibre_vence_set_from_days >/dev/null 2>&1; then
        _vence_line=$(redlibre_vence_set_from_days "$usuario" "$inputdate") || _vence_line=""
    fi
    if [[ -n "$_vence_line" ]]; then
        IFS='|' read -r _cut udata gui_hora <<<"$_vence_line"
    else
        udata=$(date "+%d/%m/%Y" -d "+$inputdate days" 2>/dev/null || date "+%d/%m/%Y" --date="+$inputdate days" 2>/dev/null)
        sysdate="$(date "+%Y-%m-%d" -d "+$inputdate days" 2>/dev/null || date "+%Y-%m-%d" --date="+$inputdate days" 2>/dev/null)"
        gui_hora="00:00"
        chage -E "$sysdate" "$usuario"
    fi
elif [[ $inputdate =~ ^[0-9]{2}/[0-9]{2}/[0-9]{4}$ ]]; then
    udata="$inputdate"
    sysdate="$(echo "$udata" | awk -v FS=/ -v OFS=- '{print $3,$2,$1}')"
    if ! date -d "$sysdate" >/dev/null 2>&1; then
        echo -e "\n\033[1;41m Fecha inexistente. \033[0m\n"
        exit 1
    fi
    if declare -F redlibre_vence_set_from_ymd >/dev/null 2>&1; then
        _vence_line=$(redlibre_vence_set_from_ymd "$usuario" "$sysdate") || _vence_line=""
    fi
    if [[ -n "$_vence_line" ]]; then
        IFS='|' read -r _cut udata gui_hora <<<"$_vence_line"
    else
        gui_hora="00:00"
        chage -E "$sysdate" "$usuario"
    fi
else
    echo -e "\n\033[1;41m Formato invГЎlido. \033[0m\n"
    exit 1
fi

hora_vencimiento=$(date +"%H:%M:%S")

echo ""
tput setaf 7
tput setab 4
tput bold
echo " ВЎГ‰XITO! PROCESO COMPLETADO "
tput sgr0
echo -e "\033[1;32mUsuario: \033[1;37m$usuario"
echo -e "\033[1;32mFecha de vencimiento: \033[1;37m$udata"
echo -e "\033[1;32mHora de corte (aprox): \033[1;37m${gui_hora:-вЂ”} (В±2 min)"
echo -e "\033[1;33mCambio realizado a las: \033[1;37m$hora_vencimiento"
echo ""
echo -e "\033[1;33mPresione \033[1;32m[ENTER]\033[1;33m para volver...\033[0m"
read -r

exit 0
