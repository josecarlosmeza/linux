#!/bin/bash
#====================================================
# Crear usuario SSH — solo revendedor (ejecutar con sudo)
# Formato alineado con /bin/criarusuario (administrador)
# Nota: con sudo+SSH a veces stdin no es la TTY; leer siempre desde /dev/tty si existe.
#====================================================
[[ -f /etc/RedLibre/redlibre-rev-common ]] && . /etc/RedLibre/redlibre-rev-common || {
    echo -e "\033[1;31mFalta /etc/RedLibre/redlibre-rev-common\033[0m"
    exit 1
}
[[ -f /etc/RedLibre/redlibre-vence-common ]] && . /etc/RedLibre/redlibre-vence-common
declare -F redlibre_vence_ensure_dir >/dev/null 2>&1 && redlibre_vence_ensure_dir

# Si el common del servidor es antiguo o truncado, definir lo que este script necesita.
if ! declare -F redlibre_rev_valid_login_name >/dev/null 2>&1; then
    redlibre_rev_valid_login_name() {
        local u="$1"
        [[ -n "$u" ]] || return 1
        [[ ${#u} -gt 3 ]] || return 1
        [[ "$u" =~ ^[a-zA-Z0-9]+$ ]] || return 1
        return 0
    }
fi
if ! declare -F redlibre_rev_auto_ssh_digit_pair >/dev/null 2>&1; then
    redlibre_rev_auto_ssh_digit_pair() {
        local rev_user="$1" only_digits="" len i
        only_digits="${rev_user//[^0-9]/}"
        len=${#only_digits}
        if [[ "$len" -ge 2 ]]; then
            i=$((RANDOM % len))
            printf '%s' "${only_digits:$i:1}"
            i=$((RANDOM % len))
            printf '%s' "${only_digits:$i:1}"
        elif [[ "$len" -eq 1 ]]; then
            printf '%s%d' "${only_digits:0:1}" $((RANDOM % 10))
        else
            printf '%d%d' $((RANDOM % 10)) $((RANDOM % 10))
        fi
    }
fi
if ! declare -F redlibre_rev_ssh_cliente_prefix >/dev/null 2>&1; then
    redlibre_rev_ssh_cliente_prefix() {
        local raw p
        raw=$(redlibre_rev_conf_get "PREFIJO_SSH_CLIENTE" "")
        raw="${raw//$'\r'/}"
        raw="${raw#"${raw%%[![:space:]]*}"}"
        raw="${raw%"${raw##*[![:space:]]}"}"
        raw="${raw,,}"
        raw="${raw//[^a-z0-9_]/}"
        if [[ -n "$raw" ]] && [[ "$raw" =~ ^[a-z] ]]; then
            printf '%s' "$raw"
            return 0
        fi
        printf 'u%s' "$(redlibre_rev_auto_ssh_digit_pair "$REV")"
    }
fi
if ! declare -F redlibre_rev_valid_prefixed_ssh_login >/dev/null 2>&1; then
    redlibre_rev_valid_prefixed_ssh_login() {
        local u="$1"
        [[ -n "$u" && ${#u} -ge 4 && ${#u} -le 32 ]] || return 1
        [[ "$u" =~ ^[a-z][a-z0-9_]+$ ]] || return 1
        return 0
    }
fi
if ! declare -F redlibre_rev_register_user >/dev/null 2>&1; then
    redlibre_rev_register_user() {
        local u="$1"
        mkdir -p "/etc/RedLibre/revendedores/$REV/usuarios"
        : >"/etc/RedLibre/revendedores/$REV/usuarios/$u"
    }
fi

if ! declare -F redlibre_rev_set_password_plain >/dev/null 2>&1; then
    redlibre_rev_set_password_plain() {
        local u="$1" p="$2" h
        [[ -n "$u" && -n "$p" ]] || return 1
        id "$u" &>/dev/null || return 1
        if printf '%s\n' "${u}:${p}" | chpasswd 2>/dev/null; then
            return 0
        fi
        if command -v openssl >/dev/null 2>&1; then
            h=$(printf '%s\n' "$p" | openssl passwd -6 -stdin 2>/dev/null) || h=""
            if [[ -z "$h" ]]; then
                h=$(openssl passwd -6 "$p" 2>/dev/null) || h=""
            fi
            if [[ -n "$h" ]] && usermod -p "$h" "$u" 2>/dev/null; then
                return 0
            fi
        fi
        return 1
    }
fi

redlibre_rev_init

_redlibre_read_tty() {
    if [[ -r /dev/tty ]]; then
        read -r "$@" < /dev/tty
    else
        read -r "$@"
    fi
}

_redlibre_strip_input() {
    local s="$1"
    s="${s//$'\r'/}"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}

_rev_pause_exit() {
    echo -ne "\033[1;33m\nPulse [ENTER] para volver al menú...\033[0m"
    if [[ -r /dev/tty ]]; then
        read -r < /dev/tty
    else
        read -r
    fi
    exit "${1:-1}"
}

[[ ! -d /etc/RedLibre/senha ]] && mkdir -p /etc/RedLibre/senha
[[ ! -f /root/usuarios.db ]] && touch /root/usuarios.db

_lim=$(redlibre_rev_limit)
_cnt=$(redlibre_rev_count_owned)
_lim="${_lim//[[:space:]]/}"
_cnt="${_cnt//[[:space:]]/}"
[[ -z "$_lim" ]] && _lim=0
[[ -z "$_cnt" ]] && _cnt=0
if [[ "$_lim" -gt 0 ]] && [[ "$_cnt" -ge "$_lim" ]]; then
    echo -e "\n\033[41;1;37m Límite de usuarios alcanzado ($_lim). Contacte al administrador. \033[0m\n"
    _rev_pause_exit 1
fi

_cap=$(redlibre_rev_max_sesiones_usuario)
_cap="${_cap//[[:space:]]/}"
[[ -z "$_cap" ]] && _cap=0
_mxt=$(redlibre_rev_conf_get "MAX_SESIONES_TOTAL_REVENDEDOR" "0")
_mxt="${_mxt//[^0-9]/}"
[[ -z "$_mxt" ]] && _mxt=0
_ssh_pfx="$(redlibre_rev_ssh_cliente_prefix)"
_rp=$(redlibre_rev_conf_get "PREFIJO_SSH_CLIENTE" "")
_rp="${_rp//$'\r'/}"
_rp="${_rp#"${_rp%%[![:space:]]*}"}"
_rp="${_rp%"${_rp##*[![:space:]]}"}"
_rp="${_rp,,}"
_rp="${_rp//[^a-z0-9_]/}"
if [[ -n "$_rp" ]] && [[ "$_rp" =~ ^[a-z] ]]; then
    _pfx_src="definido por el administrador"
else
    _pfx_src="automático (u + 2 dígitos de su usuario Linux)"
fi

clear
tput setaf 7
tput setab 4
tput bold
printf '%30s%s%-15s\n' "Crear Usuario SSH"
tput sgr0
echo ""

echo -e "\033[0;34m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
echo -e "\033[1;36m  Información — su cuenta revendedor\033[0m"
if [[ "$_lim" = "0" || -z "$_lim" ]]; then
    echo -e "\033[1;37m  • Cupo usuarios SSH: \033[1;32msin límite \033[1;37m($_cnt creados)\033[0m"
else
    echo -e "\033[1;37m  • Cupo usuarios SSH: \033[1;37m$_cnt / $_lim\033[0m"
fi
if [[ "$_cap" -gt 0 ]]; then
    echo -e "\033[1;37m  • Máx. sesiones concurrentes por cliente (admin): \033[1;33m$_cap\033[0m"
else
    echo -e "\033[1;37m  • Máx. sesiones por cliente (admin): \033[1;32msin tope\033[0m"
fi
if [[ "$_mxt" -gt 0 ]]; then
    echo -e "\033[1;37m  • Máx. sesiones SSH totales (todos sus clientes): \033[1;33m$_mxt\033[0m"
else
    echo -e "\033[1;37m  • Sesiones totales entre clientes (admin): \033[1;32msin tope global\033[0m"
fi
echo -e "\033[1;37m  • Prefijo SSH aplicado (\033[1;33m$_pfx_src\033[1;37m): \033[1;33m$_ssh_pfx\033[0m"
echo -e "\033[1;37m  • Indique solo el \033[1;33msufijo\033[1;37m (letras/números); el login será \033[1;33m${_ssh_pfx}SUFIJO\033[1;37m (4–32 caracteres en total).\033[0m"
echo -e "\033[0;34m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
echo ""

# --- Entrada de Datos (mismo estilo que criarusuario admin) ---
echo -ne "\033[1;32mSufijo del nombre de usuario (sin prefijo):\033[1;37m "
_redlibre_read_tty sufijo
sufijo=$(_redlibre_strip_input "$sufijo")
[[ -z "$sufijo" ]] && { echo -e "\n\033[1;31mSufijo vacío (¿la consola no recibió el teclado?).\033[0m\n"; _rev_pause_exit 1; }
if ! [[ "$sufijo" =~ ^[a-zA-Z0-9]+$ ]]; then
    echo -e "\n\033[1;31mSufijo inválido: solo letras y números (sin símbolos ni espacios).\033[0m\n"
    _rev_pause_exit 1
fi
_pl=${#_ssh_pfx}
_min_s=$((4 - _pl))
[[ "$_min_s" -lt 1 ]] && _min_s=1
_max_s=$((32 - _pl))
if [[ "$_max_s" -lt "$_min_s" ]]; then
    echo -e "\n\033[1;31mEl prefijo del administrador es demasiado largo; no cabe un sufijo válido.\033[0m\n"
    _rev_pause_exit 1
fi
if [[ ${#sufijo} -lt "$_min_s" ]] || [[ ${#sufijo} -gt "$_max_s" ]]; then
    echo -e "\n\033[1;31mLongitud del sufijo inválida: entre $_min_s y $_max_s caracteres (el login completo debe tener 4–32).\033[0m\n"
    _rev_pause_exit 1
fi
username="${_ssh_pfx}${sufijo}"
if ! redlibre_rev_valid_prefixed_ssh_login "$username"; then
    echo -e "\n\033[1;31mNombre de usuario completo inválido tras aplicar el prefijo.\033[0m\n"
    _rev_pause_exit 1
fi
if id "$username" &>/dev/null; then
    echo -e "\n\033[41;1;37m Error: ¡El usuario ya existe! \033[0m\n"
    _rev_pause_exit 1
fi

echo -ne "\033[1;32mContraseña:\033[1;37m "
_redlibre_read_tty password
password=$(_redlibre_strip_input "$password")
[[ -z "$password" ]] && { echo -e "\n\033[1;31mContraseña vacía.\033[0m\n"; _rev_pause_exit 1; }

echo -ne "\033[1;32mDías de validez:\033[1;37m "
_redlibre_read_tty dias
dias=$(_redlibre_strip_input "$dias")
echo -ne "\033[1;32mLímite de conexiones:\033[1;37m "
_redlibre_read_tty sshlimiter
sshlimiter=$(_redlibre_strip_input "$sshlimiter")

if ! [[ "$dias" =~ ^[0-9]+$ ]] || [[ "$dias" -lt 1 ]]; then
    echo -e "\n\033[1;31mDías inválidos.\033[0m\n"
    _rev_pause_exit 1
fi
if ! [[ "$sshlimiter" =~ ^[1-9][0-9]*$ ]]; then
    echo -e "\n\033[1;31mLímite de conexiones inválido.\033[0m\n"
    _rev_pause_exit 1
fi
if [[ "$_cap" -gt 0 ]] && [[ "$sshlimiter" -gt "$_cap" ]]; then
    echo -e "\n\033[1;33mTope del administrador: máx. $_cap sesión(es). Se usa ese valor.\033[0m"
    sshlimiter="$_cap"
fi

hora_cambio=$(date "+%H:%M:%S")

_RL_FALSE="/bin/false"
[[ -x "$_RL_FALSE" ]] || _RL_FALSE="/usr/bin/false"
[[ -x "$_RL_FALSE" ]] || _RL_FALSE="/usr/sbin/nologin"

_ua_log=$(mktemp) || exit 1
if ! useradd -M -s "$_RL_FALSE" "$username" >"$_ua_log" 2>&1; then
    echo -e "\n\033[41;1;37m Fallo al crear el usuario (useradd). \033[0m"
    echo -e "\033[1;33mDetalle:\033[0m"
    sed 's/^/  /' "$_ua_log" 2>/dev/null || cat "$_ua_log"
    echo ""
    rm -f "$_ua_log"
    _rev_pause_exit 1
fi
rm -f "$_ua_log"

if ! redlibre_rev_set_password_plain "$username" "$password"; then
    userdel --force "$username" 2>/dev/null || true
    echo -e "\n\033[41;1;37m Fallo al establecer la contraseña (chpasswd/openssl). \033[0m"
    echo -e "\033[1;33mInstale «openssl» o relaje pwquality en /etc/security/pwquality.conf si aplica.\033[0m\n"
    _rev_pause_exit 1
fi

_vence_line=""
if declare -F redlibre_vence_set_from_days >/dev/null 2>&1; then
    _vence_line=$(redlibre_vence_set_from_days "$username" "$dias") || _vence_line=""
fi
if [[ -n "$_vence_line" ]]; then
    IFS='|' read -r _cut gui gui_hora <<<"$_vence_line"
else
    final=$(date "+%Y-%m-%d" -d "+$dias days" 2>/dev/null || date "+%Y-%m-%d" --date="+$dias days" 2>/dev/null)
    gui=$(date "+%d/%m/%Y" -d "+$dias days" 2>/dev/null || date "+%d/%m/%Y" --date="+$dias days" 2>/dev/null)
    gui_hora="00:00"
    if [[ ! "$final" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
        userdel --force "$username" 2>/dev/null || true
        echo -e "\n\033[1;31mNo se pudo calcular la fecha de vencimiento (date). Revise zona horaria y locale.\033[0m\n"
        _rev_pause_exit 1
    fi
    chage -E "$final" "$username" 2>/dev/null || true
fi

echo "$password" > "/etc/RedLibre/senha/$username"
echo "$username $sshlimiter" >> /root/usuarios.db
redlibre_rev_register_user "$username"

# --- RESULTADOS (mismo bloque que criarusuario administrador) ---
clear
echo -e "\033[1;32m¡ÉXITO! PROCESO COMPLETADO\033[0m"
echo ""
echo -e "\033[1;37mUsuario: \033[1;32m$username\033[0m"
echo -e "\033[1;37mContraseña: \033[1;32m$password\033[0m"
echo -e "\033[1;37mLímite de conexiones: \033[1;32m$sshlimiter\033[0m"
echo -e "\033[1;37mFecha de vencimiento: \033[1;33m$gui\033[0m"
echo -e "\033[1;37mHora de corte (aprox): \033[1;33m${gui_hora:-—} (±2 min)\033[0m"
echo -e "\033[1;37mCambio realizado a las: $hora_cambio\033[0m"
echo ""
echo -e "\033[1;37mCódigo de acceso: \033[1;32m$username:$password\033[0m"
echo ""
echo -ne "\033[1;33mPresione [ENTER] para volver a la consola...\033[0m"
_redlibre_read_tty _

exit 0
