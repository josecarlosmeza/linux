#!/bin/bash
#====================================================
# Crear usuario SSH — solo revendedor (ejecutar con sudo)
#====================================================
[[ -f /etc/RedLibre/redlibre-rev-common ]] && . /etc/RedLibre/redlibre-rev-common || {
    echo -e "\033[1;31mFalta /etc/RedLibre/redlibre-rev-common\033[0m"
    exit 1
}
redlibre_rev_init

for pkg in perl curl; do
    command -v "$pkg" >/dev/null 2>&1 || { command -v dnf >/dev/null 2>&1 && dnf install -y "$pkg"; } || { command -v yum >/dev/null 2>&1 && yum install -y "$pkg"; }
done

[[ ! -d /etc/RedLibre/senha ]] && mkdir -p /etc/RedLibre/senha
[[ ! -f /root/usuarios.db ]] && touch /root/usuarios.db

_lim=$(redlibre_rev_limit)
_cnt=$(redlibre_rev_count_owned)
if [[ "$_lim" -gt 0 ]] && [[ "$_cnt" -ge "$_lim" ]]; then
    echo -e "\n\033[41;1;37m Límite de usuarios alcanzado ($_lim). Contacte al administrador. \033[0m\n"
    exit 1
fi

clear
tput setaf 7
tput setab 4
tput bold
printf '%30s%s%-15s\n' "Crear usuario SSH (revendedor)"
tput sgr0
echo ""
_cap=$(redlibre_rev_max_sesiones_usuario)
[[ "$_cap" -gt 0 ]] && echo -e "\033[1;36mTope de sesiones por usuario (admin): \033[1;37m$_cap\033[0m"
echo ""
read -r username
[[ -z "$username" ]] && { echo -e "\n\033[1;31mNombre vacío.\033[0m\n"; exit 1; }
if id "$username" &>/dev/null; then
    echo -e "\n\033[41;1;37m Error: ¡El usuario ya existe! \033[0m\n"
    exit 1
fi

echo -ne "\033[1;32mContraseña:\033[1;37m "
read -r password
[[ -z "$password" ]] && { echo -e "\n\033[1;31mContraseña vacía.\033[0m\n"; exit 1; }

echo -ne "\033[1;32mDías de validez:\033[1;37m "
read -r dias
echo -ne "\033[1;32mLímite de conexiones:\033[1;37m "
read -r sshlimiter

if ! [[ "$dias" =~ ^[0-9]+$ ]] || [[ "$dias" -lt 1 ]]; then
    echo -e "\n\033[1;31mDías inválidos.\033[0m\n"
    exit 1
fi
if ! [[ "$sshlimiter" =~ ^[1-9][0-9]*$ ]]; then
    echo -e "\n\033[1;31mLímite de conexiones inválido.\033[0m\n"
    exit 1
fi
_cap=$(redlibre_rev_max_sesiones_usuario)
if [[ "$_cap" -gt 0 ]] && [[ "$sshlimiter" -gt "$_cap" ]]; then
    echo -e "\n\033[1;33mTope del administrador: máx. $_cap sesión(es). Se usa ese valor.\033[0m"
    sshlimiter="$_cap"
fi

final=$(date "+%Y-%m-%d" -d "+$dias days")
gui=$(date "+%d/%m/%Y" -d "+$dias days")
hora_cambio=$(date "+%H:%M:%S")

pass=$(perl -e 'print crypt($ARGV[0], "password")' "$password")
if ! useradd -e "$final" -M -s /bin/false -p "$pass" "$username" >/dev/null 2>&1; then
    echo -e "\n\033[41;1;37m Fallo al crear el usuario. \033[0m\n"
    exit 1
fi

echo "$password" > "/etc/RedLibre/senha/$username"
echo "$username $sshlimiter" >> /root/usuarios.db
redlibre_rev_register_user "$username"

clear
echo -e "\033[1;32m¡ÉXITO! PROCESO COMPLETADO\033[0m"
echo ""
echo -e "\033[1;37mUsuario: \033[1;32m$username\033[0m"
echo -e "\033[1;37mContraseña: \033[1;32m$password\033[0m"
echo -e "\033[1;37mLímite de conexiones: \033[1;32m$sshlimiter\033[0m"
echo -e "\033[1;37mFecha de vencimiento: \033[1;33m$gui\033[0m"
echo -e "\033[1;37mCambio realizado a las: $hora_cambio\033[0m"
echo ""
echo -e "\033[1;37mCódigo de acceso: \033[1;32m$username:$password\033[0m"
echo ""
echo -ne "\033[1;33mPresione [ENTER] para continuar...\033[0m"
read -r

exit 0
