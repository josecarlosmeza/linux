#!/bin/bash
#====================================================
# Crear usuario SSH вҖ” solo revendedor (ejecutar con sudo)
# Formato alineado con /bin/criarusuario (administrador)
#====================================================
[[ -f /etc/RedLibre/redlibre-rev-common ]] && . /etc/RedLibre/redlibre-rev-common || {
    echo -e "\033[1;31mFalta /etc/RedLibre/redlibre-rev-common\033[0m"
    exit 1
}
redlibre_rev_init

[[ ! -d /etc/RedLibre/senha ]] && mkdir -p /etc/RedLibre/senha
[[ ! -f /root/usuarios.db ]] && touch /root/usuarios.db

_lim=$(redlibre_rev_limit)
_cnt=$(redlibre_rev_count_owned)
if [[ "$_lim" -gt 0 ]] && [[ "$_cnt" -ge "$_lim" ]]; then
    echo -e "\n\033[41;1;37m LГӯmite de usuarios alcanzado ($_lim). Contacte al administrador. \033[0m\n"
    exit 1
fi

_cap=$(redlibre_rev_max_sesiones_usuario)
_mxt=$(redlibre_rev_conf_get "MAX_SESIONES_TOTAL_REVENDEDOR" "0")
_mxt="${_mxt//[^0-9]/}"
[[ -z "$_mxt" ]] && _mxt=0

clear
tput setaf 7
tput setab 4
tput bold
printf '%30s%s%-15s\n' "Crear Usuario SSH"
tput sgr0
echo ""

echo -e "\033[0;34mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\033[0m"
echo -e "\033[1;36m  InformaciГіn вҖ” su cuenta revendedor\033[0m"
if [[ "$_lim" = "0" || -z "$_lim" ]]; then
    echo -e "\033[1;37m  вҖў Cupo usuarios SSH: \033[1;32msin lГӯmite \033[1;37m($_cnt creados)\033[0m"
else
    echo -e "\033[1;37m  вҖў Cupo usuarios SSH: \033[1;37m$_cnt / $_lim\033[0m"
fi
if [[ "$_cap" -gt 0 ]]; then
    echo -e "\033[1;37m  вҖў MГЎx. sesiones concurrentes por cliente (admin): \033[1;33m$_cap\033[0m"
else
    echo -e "\033[1;37m  вҖў MГЎx. sesiones por cliente (admin): \033[1;32msin tope\033[0m"
fi
if [[ "$_mxt" -gt 0 ]]; then
    echo -e "\033[1;37m  вҖў MГЎx. sesiones SSH totales (todos sus clientes): \033[1;33m$_mxt\033[0m"
else
    echo -e "\033[1;37m  вҖў Sesiones totales entre clientes (admin): \033[1;32msin tope global\033[0m"
fi
echo -e "\033[1;37m  вҖў Nombre de usuario: mГЎs de 3 caracteres, solo \033[1;33mletras y nГәmeros\033[1;37m.\033[0m"
echo -e "\033[0;34mв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\033[0m"
echo ""

# --- Entrada de Datos (mismo estilo que criarusuario admin) ---
echo -ne "\033[1;32mNombre de usuario:\033[1;37m "
read -r username
[[ -z "$username" ]] && { echo -e "\n\033[1;31mNombre vacГӯo.\033[0m\n"; exit 1; }
if ! redlibre_rev_valid_login_name "$username"; then
    echo -e "\n\033[1;31mNombre invГЎlido: debe tener mГЎs de 3 caracteres y solo letras y nГәmeros (sin sГӯmbolos ni espacios).\033[0m\n"
    exit 1
fi
if id "$username" &>/dev/null; then
    echo -e "\n\033[41;1;37m Error: ВЎEl usuario ya existe! \033[0m\n"
    exit 1
fi

echo -ne "\033[1;32mContraseГұa:\033[1;37m "
read -r password
[[ -z "$password" ]] && { echo -e "\n\033[1;31mContraseГұa vacГӯa.\033[0m\n"; exit 1; }

echo -ne "\033[1;32mDГӯas de validez:\033[1;37m "
read -r dias
echo -ne "\033[1;32mLГӯmite de conexiones:\033[1;37m "
read -r sshlimiter

if ! [[ "$dias" =~ ^[0-9]+$ ]] || [[ "$dias" -lt 1 ]]; then
    echo -e "\n\033[1;31mDГӯas invГЎlidos.\033[0m\n"
    exit 1
fi
if ! [[ "$sshlimiter" =~ ^[1-9][0-9]*$ ]]; then
    echo -e "\n\033[1;31mLГӯmite de conexiones invГЎlido.\033[0m\n"
    exit 1
fi
if [[ "$_cap" -gt 0 ]] && [[ "$sshlimiter" -gt "$_cap" ]]; then
    echo -e "\n\033[1;33mTope del administrador: mГЎx. $_cap sesiГіn(es). Se usa ese valor.\033[0m"
    sshlimiter="$_cap"
fi

final=$(date "+%Y-%m-%d" -d "+$dias days" 2>/dev/null || date "+%Y-%m-%d" --date="+$dias days")
gui=$(date "+%d/%m/%Y" -d "+$dias days" 2>/dev/null || date "+%d/%m/%Y" --date="+$dias days")
hora_cambio=$(date "+%H:%M:%S")

# Mismo criterio que importaciГіn y criarteste-rev: chpasswd (hash del sistema, sin lГӯmite DES de crypt "password")
if ! useradd -e "$final" -M -s /bin/false "$username" >/dev/null 2>&1; then
    echo -e "\n\033[41;1;37m Fallo al crear el usuario. \033[0m\n"
    exit 1
fi
if ! echo "$username:$password" | chpasswd 2>/dev/null; then
    userdel --force "$username" 2>/dev/null || true
    echo -e "\n\033[41;1;37m Fallo al establecer la contraseГұa (chpasswd). \033[0m\n"
    exit 1
fi

echo "$password" > "/etc/RedLibre/senha/$username"
echo "$username $sshlimiter" >> /root/usuarios.db
redlibre_rev_register_user "$username"

# --- RESULTADOS (mismo bloque que criarusuario administrador) ---
clear
echo -e "\033[1;32mВЎГүXITO! PROCESO COMPLETADO\033[0m"
echo ""
echo -e "\033[1;37mUsuario: \033[1;32m$username\033[0m"
echo -e "\033[1;37mContraseГұa: \033[1;32m$password\033[0m"
echo -e "\033[1;37mLГӯmite de conexiones: \033[1;32m$sshlimiter\033[0m"
echo -e "\033[1;37mFecha de vencimiento: \033[1;33m$gui\033[0m"
echo -e "\033[1;37mHora de corte (aprox): 00:00:01 AM\033[0m"
echo -e "\033[1;37mCambio realizado a las: $hora_cambio\033[0m"
echo ""
echo -e "\033[1;37mCГіdigo de acceso: \033[1;32m$username:$password\033[0m"
echo ""
echo -ne "\033[1;33mPresione [ENTER] para volver a la consola...\033[0m"
read -r

exit 0
