#!/bin/bash
[[ -f /etc/RedLibre/redlibre-rev-common ]] && . /etc/RedLibre/redlibre-rev-common || exit 1
[[ -f /etc/RedLibre/redlibre-vence-common ]] && . /etc/RedLibre/redlibre-vence-common
redlibre_rev_init

clear
tput setaf 7
tput setab 4
tput bold
printf '%33s%s%-12s\n' "Modificar vencimiento (revendedor)"
tput sgr0
echo ""
echo -e "\033[1;33m SUS USUARIOS:\033[0m "
echo ""

list_user=$(redlibre_rev_list_owned)
if [[ -z "$list_user" ]]; then
    echo -e "\033[1;31mNo tiene usuarios.\033[0m"
    sleep 2
    exit 0
fi

i=0
_userPass=""

while read -r user; do
    [[ -z "$user" ]] && continue
    i=$((i + 1))
    if (( i < 10 )); then _idx_display="0$i"; else _idx_display="$i"; fi

    expire="$(LANG=en_US.UTF-8 chage -l "$user" 2>/dev/null | grep -E "Account expires" | cut -d ' ' -f3-)"

    if [[ $expire == "never" ]]; then
        echo -e "\033[1;31m[\033[1;36m$_idx_display\033[1;31m] \033[1;37m- \033[1;32m$user     \033[1;33m00/00/0000   SIN FECHA\033[0m"
    else
        databr="$(date -d "$expire" +"%Y%m%d" 2>/dev/null)"
        hoje="$(date -d today +"%Y%m%d" 2>/dev/null)"
        if [ "$hoje" -ge "$databr" ] 2>/dev/null; then
            _u=$(echo -e "\033[1;31m[\033[1;36m$_idx_display\033[1;31m] \033[1;37m- \033[1;32m$user\033[1;37m")
            datanormal="$(echo -e "\033[1;31m$(date -d "$expire" '+%d/%m/%Y' 2>/dev/null)\033[0m")"
            expired=$(echo -e "\033[1;31mEXPIRADO\033[0m")
            printf '%-62s%-20s%s\n' "$_u" "$datanormal" "$expired"
        else
            _u=$(echo -e "\033[1;31m[\033[1;36m$_idx_display\033[1;31m] \033[1;37m- \033[1;32m$user\033[1;37m")
            datanormal="$(echo -e "\033[1;33m$(date -d "$expire" '+%d/%m/%Y' 2>/dev/null)\033[0m")"
            ative=$(echo -e "\033[1;32mVГЃLIDO\033[0m")
            printf '%-62s%-20s%s\n' "$_u" "$datanormal" "$ative"
        fi
    fi
    _userPass="${_userPass}${_idx_display}:${user}\n"
done <<< "$list_user"

tput sgr0
echo ""

num_user=$i
echo -ne "\033[1;32mNГєmero o nombre de usuario \033[1;33m[\033[1;36m1\033[1;36m-$num_user\033[1;33m]\033[1;37m: "
read -r option

[[ -z $option ]] && exit 1

if [[ $option =~ ^[0-9]+$ ]]; then
    usuario=$(printf '%b' "$_userPass" | grep -E "^0*${option}:" | head -1 | cut -d: -f2)
else
    usuario=$option
fi

if [[ -z "$usuario" ]] || ! redlibre_rev_owned "$usuario"; then
    echo -e "\n\033[1;41m SelecciГіn invГЎlida. \033[0m\n"
    exit 1
fi

if ! id "$usuario" >/dev/null 2>&1; then
    echo -e "\n\033[1;41m El usuario '$usuario' no existe. \033[0m\n"
    exit 1
fi

expire_raw=$(LANG=en_US.UTF-8 chage -l "$usuario" 2>/dev/null | grep "Account expires" | awk -F': ' '{print $2}' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
echo ""
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
echo -e "\033[1;33m  Usuario: \033[1;32m$usuario\033[0m"
if [[ -z "$expire_raw" || "$expire_raw" == "never" ]]; then
    echo -e "\033[1;32m  Vencimiento: \033[1;37mSin fecha\033[0m"
else
    fecha_venc=$(date --date="$expire_raw" '+%d/%m/%Y' 2>/dev/null || date -d "$expire_raw" '+%d/%m/%Y' 2>/dev/null)
    echo -e "\033[1;32m  Vencimiento: \033[1;37m$fecha_venc\033[0m"
fi
echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
echo ""
echo -e "\033[1;32mEjemplos: \033[1;37m'30' (dГ­as) o '21/12/2026' (fecha)\033[0m"
echo ""
echo -ne "\033[1;32mNueva fecha para \033[1;33m$usuario: \033[1;37m"
read -r inputdate

[[ -f /etc/RedLibre/redlibre-vence-common ]] && . /etc/RedLibre/redlibre-vence-common

_vence_line=""
gui_hora=""
if [[ $inputdate =~ ^[0-9]+$ ]]; then
    if declare -F redlibre_vence_set_from_days >/dev/null 2>&1; then
        _vence_line=$(redlibre_vence_set_from_days "$usuario" "$inputdate") || _vence_line=""
    fi
    if [[ -n "$_vence_line" ]]; then
        IFS='|' read -r _cut udata gui_hora <<<"$_vence_line"
    else
        udata=$(date "+%d/%m/%Y" -d "+$inputdate days" 2>/dev/null)
        sysdate="$(date "+%Y-%m-%d" -d "+$inputdate days" 2>/dev/null)"
        gui_hora="00:00"
        chage -E "$sysdate" "$usuario"
    fi
elif [[ $inputdate =~ ^[0-9]{2}/[0-9]{2}/[0-9]{4}$ ]]; then
    udata="$inputdate"
    sysdate="$(echo "$udata" | awk -v FS=/ -v OFS=- '{print $3,$2,$1}')"
    if ! date -d "$sysdate" >/dev/null 2>&1; then
        echo -e "\n\033[1;41m Fecha invГЎlida. \033[0m"
        exit 1
    fi
    if declare -F redlibre_vence_set_from_ymd >/dev/null 2>&1; then
        _vence_line=$(redlibre_vence_set_from_ymd "$usuario" "$sysdate") || _vence_line=""
    fi
    if [[ -n "$_vence_line" ]]; then
        IFS='|' read -r _cut udata gui_hora <<<"$_vence_line"
    else
        gui_hora="00:00"
        chage -E "$sysdate" "$usuario"
    fi
else
    echo -e "\n\033[1;41m Formato invГЎlido. \033[0m"
    exit 1
fi

hora_vencimiento=$(date +"%H:%M:%S")

echo ""
tput setaf 7
tput setab 4
tput bold
echo " ВЎГ‰XITO! "
tput sgr0
echo -e "\033[1;32mUsuario: \033[1;37m$usuario"
echo -e "\033[1;32mNuevo vencimiento: \033[1;37m$udata"
echo -e "\033[1;32mHora de corte (aprox): \033[1;37m${gui_hora:-вЂ”} (В±2 min)"
echo -e "\033[1;33mCambio a las: \033[1;37m$hora_vencimiento"
echo ""
echo -e "\033[1;33mPresione [ENTER]...\033[0m"
read -r

exit 0
