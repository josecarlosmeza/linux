#!/bin/bash
#====================================================
# Submenú — Limitador tiempo real (screen) vs PAM
# Scripts PAM: Subir a otro Servidor/Limitador/ (limitador-completo.sh, etc.)
#====================================================
[[ $EUID -eq 0 ]] || {
    echo -e "\033[1;31mEjecute como root.\033[0m"
    exit 1
}

URL_BASE="https://github.com/josecarlosmeza/linux/raw/main/Subir%20a%20otro%20Servidor/Limitador"

_redlibre_rt_running() {
    ps x 2>/dev/null | grep '[l]imiter' >/dev/null 2>&1
}

_redlibre_rt_status() {
    if _redlibre_rt_running; then
        printf '%s' "ACTIVO (screen / proceso limiter)"
    else
        printf '%s' "INACTIVO"
    fi
}

_redlibre_pam_active() {
    grep -qE 'pam_exec\.so.*check_ssh_limits\.sh' /etc/pam.d/sshd 2>/dev/null
}

_redlibre_pam_status() {
    if _redlibre_pam_active; then
        printf '%s' "ACTIVO (pam_exec → check_ssh_limits.sh)"
    else
        printf '%s' "INACTIVO / no configurado en PAM"
    fi
}

_redlibre_guardian_text() {
    if ! command -v systemctl >/dev/null 2>&1; then
        echo "systemd no disponible — no se muestra guardián."
        return
    fi
    if [[ ! -f /etc/systemd/system/db-guardian.service ]]; then
        echo -e "\033[1;33m  Estado: \033[1;37mNO INSTALADO\033[0m"
        echo -e "\033[1;37m  (Se instala con la opción 2 en Alma/RHEL vía limitador-completo.sh.)\033[0m"
        return
    fi
    if systemctl is-active --quiet db-guardian.service 2>/dev/null; then
        local ts line
        ts=$(systemctl show db-guardian.service -p ActiveEnterTimestamp --value 2>/dev/null)
        line=$(journalctl -u db-guardian.service -n 1 --no-pager -o short-iso 2>/dev/null | head -1)
        echo -e "\033[1;33m  Estado: \033[1;32mACTIVO\033[0m"
        echo -e "\033[1;33m  Activo desde: \033[1;37m${ts:-—}\033[0m"
        echo -e "\033[1;33m  Último log:    \033[1;37m${line:-—}\033[0m"
    else
        echo -e "\033[1;33m  Estado: \033[1;31mINACTIVO\033[0m (unidad presente)"
        local line
        line=$(journalctl -u db-guardian.service -n 1 --no-pager -o short-iso 2>/dev/null | head -1)
        [[ -n "$line" ]] && echo -e "\033[1;33m  Último log:    \033[1;37m$line\033[0m"
    fi
}

_redlibre_pam_remove() {
    sed -i '/pam_exec\.so.*check_ssh_limits\.sh/d' /etc/pam.d/sshd 2>/dev/null || true
}

_redlibre_rt_stop() {
    screen -S limiter -X quit 2>/dev/null
    screen -wipe 1>/dev/null 2>&1
    if [[ -f /etc/autostart ]] && grep -q limiter /etc/autostart 2>/dev/null; then
        sed -i '/limiter/d' /etc/autostart
    fi
}

_redlibre_rt_start() {
    screen -dmS limiter limiter 2>/dev/null
    sleep 1
    if [[ ! -f /etc/autostart ]]; then
        {
            echo '#!/bin/bash'
            echo 'clear'
            echo '#INICIO AUTOMÁTICO'
        } >/etc/autostart
        chmod +x /etc/autostart 2>/dev/null || true
    fi
    if [[ $(grep -wc "limiter" /etc/autostart 2>/dev/null || echo 0) -eq 0 ]]; then
        echo "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >>/etc/autostart
    else
        sed -i '/limiter/d' /etc/autostart
        echo "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >>/etc/autostart
    fi
}

_redlibre_is_rhel_like() {
    [[ -f /etc/redhat-release ]] && grep -qiE 'almalinux|rocky|rhel|centos|fedora|oracle' /etc/redhat-release 2>/dev/null
}

_redlibre_install_pam_stack() {
    local tmp ec=0
    echo -e "\033[1;32mDescargando e instalando limitador PAM…\033[0m"
    if _redlibre_is_rhel_like; then
        tmp=$(mktemp) || return 1
        if ! wget -qO "$tmp" "${URL_BASE}/limitador-completo.sh"; then
            rm -f "$tmp"
            echo -e "\033[1;31mNo se pudo descargar limitador-completo.sh\033[0m"
            return 1
        fi
        chmod +x "$tmp"
        bash "$tmp" || ec=$?
        rm -f "$tmp"
    else
        tmp=$(mktemp) || return 1
        if ! wget -qO "$tmp" "${URL_BASE}/limitador-openssh"; then
            rm -f "$tmp"
            echo -e "\033[1;31mNo se pudo descargar limitador-openssh\033[0m"
            return 1
        fi
        chmod +x "$tmp"
        bash "$tmp" || ec=$?
        rm -f "$tmp"
        echo -e "\033[1;33mEn Debian/Ubuntu se usó limitador-openssh (PAM sobre /root/usuarios.db).\033[0m"
        echo -e "\033[1;33mOpcional: en el repo, Limitador/limitador-guardian-sshd para db-guardian.\033[0m"
    fi
    return "$ec"
}

while true; do
    clear
    tput setaf 7
    tput setab 4
    tput bold
    printf '%32s%s%-10s\n' "Gestión del limitador"
    tput sgr0
    echo ""
    echo -e "\033[0;34m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo -e "\033[1;33m  Limitador tiempo real (screen / \033[1;37m/bin/limiter\033[1;33m)\033[0m"
    echo -e "\033[1;33m    → \033[1;37m$(_redlibre_rt_status)\033[0m"
    echo ""
    echo -e "\033[1;33m  Limitador por PAM (\033[1;37mcheck_ssh_limits.sh\033[1;33m)\033[0m"
    echo -e "\033[1;33m    → \033[1;37m$(_redlibre_pam_status)\033[0m"
    echo ""
    echo -e "\033[1;33m  Guardián de base de datos (\033[1;37mdb-guardian.service\033[1;33m)\033[0m"
    _redlibre_guardian_text
    echo -e "\033[1;37m  Nota: el guardián no se detiene ni se deshabilita con las opciones 1, 3 ni 4.\033[0m"
    echo -e "\033[0;34m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m]\033[1;33m Activar limitador en \033[1;37mtiempo real\033[1;33m (quita solo PAM del limitador; el guardián sigue)\033[0m"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m]\033[1;33m Activar limitador por \033[1;37mPAM\033[1;33m (descarga e instala; detiene tiempo real)\033[0m"
    echo -e "\033[1;31m[\033[1;36m3\033[1;31m]\033[1;33m Parar \033[1;37mlimitadores de sesión\033[1;33m: screen y PAM (\033[1;37msin tocar el guardián\033[1;33m)\033[0m"
    echo -e "\033[1;31m[\033[1;36m4\033[1;31m]\033[1;33m Activar \033[1;37mPAM y tiempo real a la vez\033[1;33m (doble control; ver aviso)\033[0m"
    echo -e "\033[1;31m[\033[1;36m0\033[1;31m]\033[1;33m Volver al menú principal\033[0m"
    echo ""
    echo -ne "\033[1;32mOpción: \033[1;37m"
    read -r _op

    case "${_op:-}" in
        1)
            clear
            echo -e "\033[1;32mActivando limitador en tiempo real…\033[0m"
            _redlibre_pam_remove
            _redlibre_rt_start
            echo -e "\033[1;32mListo. PAM del limitador desmontado en /etc/pam.d/sshd (si estaba); screen limiter iniciado.\033[0m"
            echo -e "\033[1;37mNo se ha reiniciado ni recargado sshd (no corta sesiones SSH actuales).\033[0m"
            echo -e "\033[1;37mEl servicio db-guardian no se ha modificado.\033[0m"
            echo -ne "\033[1;33m[ENTER]\033[0m "
            read -r
            ;;
        2)
            clear
            echo -e "\033[1;32mPreparando limitador PAM (se detiene el limitador en tiempo real)…\033[0m"
            _redlibre_rt_stop
            _redlibre_install_pam_stack
            echo -e "\033[1;33mRevise mensajes anteriores. Reinicie SSH manualmente si el script lo indicó.\033[0m"
            echo -ne "\033[1;33m[ENTER]\033[0m "
            read -r
            ;;
        3)
            clear
            echo -e "\033[1;31mDeteniendo limitadores de sesión (screen y PAM)…\033[0m"
            _redlibre_rt_stop
            _redlibre_pam_remove
            echo -e "\033[1;32mHecho: screen limiter parado y líneas PAM del limitador eliminadas de /etc/pam.d/sshd.\033[0m"
            echo -e "\033[1;37mNo se ha reiniciado ni recargado sshd.\033[0m"
            echo -e "\033[1;37mdb-guardian no se ha detenido ni deshabilitado.\033[0m"
            echo -ne "\033[1;33m[ENTER]\033[0m "
            read -r
            ;;
        4)
            clear
            echo -e "\033[1;33mPAM y limitador en tiempo real pueden funcionar a la vez.\033[0m"
            echo -e "\033[1;37m• PAM suele bloquear nuevas conexiones al superar el límite.\033[0m"
            echo -e "\033[1;37m• El script en screen mata sesiones según el log de auth (\033[1;33msecure\033[1;37m / \033[1;33mauth.log\033[1;37m); el conteo puede diferir del PAM.\033[0m"
            echo -e "\033[1;37m• Use la misma \033[1;33musuarios.db\033[1;37m; con instalación «completa» PAM lee la copia sincronizada por el guardián.\033[0m"
            echo -e "\033[1;33mSi no necesita redundancia, use solo la opción 1 o 2.\033[0m"
            echo ""
            if ! _redlibre_pam_active; then
                echo -e "\033[1;32mInstalando / activando PAM…\033[0m"
                _redlibre_install_pam_stack
            else
                echo -e "\033[1;37mPAM del limitador ya estaba configurado; no se reinstala.\033[0m"
            fi
            echo -e "\033[1;32mIniciando limitador en tiempo real (screen)…\033[0m"
            _redlibre_rt_start
            echo -e "\033[1;32mListo: ambos mecanismos quedan activos si la instalación PAM tuvo éxito.\033[0m"
            echo -ne "\033[1;33m[ENTER]\033[0m "
            read -r
            ;;
        0 | 00)
            exit 0
            ;;
        *)
            echo -e "\033[1;31mOpción no válida.\033[0m"
            sleep 2
            ;;
    esac
done
