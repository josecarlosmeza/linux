#!/bin/bash
#====================================================
# SubmenГє вЂ” Limitador tiempo real (screen) vs PAM
# Scripts PAM: Subir a otro Servidor/Limitador/ (limitador-completo.sh, etc.)
#====================================================
[[ $EUID -eq 0 ]] || {
    echo -e "\033[1;31mEjecute como root.\033[0m"
    exit 1
}

URL_BASE="https://github.com/josecarlosmeza/linux/raw/main/Subir%20a%20otro%20Servidor/Limitador"

_redlibre_rt_running() {
    # В«limiterВ» en ps tambiГ©n coincide con /bin/droplimiter (subcadena В«limiterВ»); excluir falsos positivos.
    pgrep -x limiter &>/dev/null && return 0
    ps x 2>/dev/null | grep '[l]imiter' | grep -Fv 'droplimiter' | grep -q . && return 0
    return 1
}

_redlibre_rt_status() {
    if _redlibre_rt_running; then
        printf '%s' "ACTIVO (screen / proceso limiter)"
    else
        printf '%s' "INACTIVO"
    fi
}

_redlibre_pam_active() {
    grep -qE 'pam_exec\.so.*check_ssh_limits\.sh' /etc/pam.d/sshd 2>/dev/null
}

_redlibre_pam_status() {
    if _redlibre_pam_active; then
        printf '%s' "ACTIVO (pam_exec в†’ check_ssh_limits.sh)"
    else
        printf '%s' "INACTIVO / no configurado en PAM"
    fi
}

_redlibre_guardian_text() {
    if ! command -v systemctl >/dev/null 2>&1; then
        echo "systemd no disponible вЂ” no se muestra guardiГЎn."
        return
    fi
    if [[ ! -f /etc/systemd/system/db-guardian.service ]]; then
        echo -e "\033[1;33m  Estado: \033[1;37mNO INSTALADO\033[0m"
        echo -e "\033[1;37m  (Se instala con la opciГіn 2 en Alma/RHEL vГ­a limitador-completo.sh.)\033[0m"
        return
    fi
    if systemctl is-active --quiet db-guardian.service 2>/dev/null; then
        local ts line
        ts=$(systemctl show db-guardian.service -p ActiveEnterTimestamp --value 2>/dev/null)
        line=$(journalctl -u db-guardian.service -n 1 --no-pager -o short-iso 2>/dev/null | head -1)
        echo -e "\033[1;33m  Estado: \033[1;32mACTIVO\033[0m"
        echo -e "\033[1;33m  Activo desde: \033[1;37m${ts:-вЂ”}\033[0m"
        echo -e "\033[1;33m  Гљltimo log:    \033[1;37m${line:-вЂ”}\033[0m"
    else
        echo -e "\033[1;33m  Estado: \033[1;31mINACTIVO\033[0m (unidad presente)"
        local line
        line=$(journalctl -u db-guardian.service -n 1 --no-pager -o short-iso 2>/dev/null | head -1)
        [[ -n "$line" ]] && echo -e "\033[1;33m  Гљltimo log:    \033[1;37m$line\033[0m"
    fi
}

_redlibre_pam_remove() {
    sed -i '/pam_exec\.so.*check_ssh_limits\.sh/d' /etc/pam.d/sshd 2>/dev/null || true
}

_redlibre_rt_stop() {
    screen -S limiter -X quit 2>/dev/null
    screen -wipe 1>/dev/null 2>&1
    # Si el proceso sigue sin screen (p. ej. relanzado entre cron y autostart), matar el watcher explГ­cito.
    pkill -x limiter 2>/dev/null || true
    pkill -f '[/]bin/limiter' 2>/dev/null || true
    pkill -f '[/]usr/bin/limiter' 2>/dev/null || true
    if [[ -f /etc/autostart ]] && grep -q limiter /etc/autostart 2>/dev/null; then
        sed -i '/limiter/d' /etc/autostart
    fi
}

_redlibre_screen_prepare() {
    # screen exige /run/screen con permisos amplios (en algunas distros 777).
    mkdir -p /run/screen 2>/dev/null || true
    chmod 777 /run/screen 2>/dev/null || true
}

_redlibre_rt_start() {
    _redlibre_screen_prepare
    screen -dmS limiter limiter 2>/dev/null
    sleep 1
    if [[ ! -f /etc/autostart ]]; then
        {
            echo '#!/bin/bash'
            echo 'clear'
            echo '#INICIO AUTOMГЃTICO'
        } >/etc/autostart
        chmod +x /etc/autostart 2>/dev/null || true
    fi
    # grep -c con 0 coincidencias imprime "0" pero cГіdigo de salida 1; no usar "|| echo 0" (duplica y rompe [[ ]]).
    local _lc
    _lc=0
    [[ -f /etc/autostart ]] && _lc=$(grep -Fsc limiter /etc/autostart 2>/dev/null)
    _lc="${_lc//[^0-9]/}"
    [[ -z "$_lc" ]] && _lc=0
    if [[ "$_lc" -eq 0 ]]; then
        echo "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >>/etc/autostart
    else
        sed -i '/limiter/d' /etc/autostart
        echo "ps x | grep 'limiter' | grep -v 'grep' && echo 'ON' || screen -dmS limiter limiter" >>/etc/autostart
    fi
}

_redlibre_is_rhel_like() {
    [[ -f /etc/redhat-release ]] && grep -qiE 'almalinux|rocky|rhel|centos|fedora|oracle' /etc/redhat-release 2>/dev/null
}

_redlibre_install_pam_stack() {
    local tmp ec=0
    echo -e "\033[1;32mDescargando e instalando limitador PAMвЂ¦\033[0m"
    if _redlibre_is_rhel_like; then
        tmp=$(mktemp) || return 1
        if ! wget -qO "$tmp" "${URL_BASE}/limitador-completo.sh"; then
            rm -f "$tmp"
            echo -e "\033[1;31mNo se pudo descargar limitador-completo.sh\033[0m"
            return 1
        fi
        chmod +x "$tmp"
        bash "$tmp" || ec=$?
        rm -f "$tmp"
    else
        tmp=$(mktemp) || return 1
        if ! wget -qO "$tmp" "${URL_BASE}/limitador-openssh"; then
            rm -f "$tmp"
            echo -e "\033[1;31mNo se pudo descargar limitador-openssh\033[0m"
            return 1
        fi
        chmod +x "$tmp"
        bash "$tmp" || ec=$?
        rm -f "$tmp"
        echo -e "\033[1;33mEn Debian/Ubuntu se usГі limitador-openssh (PAM sobre /root/usuarios.db).\033[0m"
        echo -e "\033[1;33mOpcional: en el repo, Limitador/limitador-guardian-sshd para db-guardian.\033[0m"
    fi
    return "$ec"
}

while true; do
    clear
    tput setaf 7
    tput setab 4
    tput bold
    printf '%32s%s%-10s\n' "GestiГіn del limitador"
    tput sgr0
    echo ""
    echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
    echo -e "\033[1;33m  Limitador tiempo real (screen / \033[1;37m/bin/limiter\033[1;33m)\033[0m"
    echo -e "\033[1;33m    в†’ \033[1;37m$(_redlibre_rt_status)\033[0m"
    echo ""
    echo -e "\033[1;33m  Limitador por PAM (\033[1;37mcheck_ssh_limits.sh\033[1;33m)\033[0m"
    echo -e "\033[1;33m    в†’ \033[1;37m$(_redlibre_pam_status)\033[0m"
    echo ""
    echo -e "\033[1;33m  GuardiГЎn de base de datos (\033[1;37mdb-guardian.service\033[1;33m)\033[0m"
    _redlibre_guardian_text
    echo -e "\033[1;37m  Nota: el guardiГЎn no se detiene ni se deshabilita con las opciones 1, 3 ni 4.\033[0m"
    echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
    echo ""
    echo -e "\033[1;31m[\033[1;36m1\033[1;31m]\033[1;33m Activar limitador en \033[1;37mtiempo real\033[1;33m (quita solo PAM del limitador; el guardiГЎn sigue)\033[0m"
    echo -e "\033[1;31m[\033[1;36m2\033[1;31m]\033[1;33m Activar limitador por \033[1;37mPAM\033[1;33m (descarga e instala; detiene tiempo real)\033[0m"
    echo -e "\033[1;31m[\033[1;36m3\033[1;31m]\033[1;33m Parar \033[1;37mlimitadores de sesiГіn\033[1;33m: screen y PAM (\033[1;37msin tocar el guardiГЎn\033[1;33m)\033[0m"
    echo -e "\033[1;31m[\033[1;36m4\033[1;31m]\033[1;33m Activar \033[1;37mPAM y tiempo real a la vez\033[1;33m (doble control; ver aviso)\033[0m"
    echo -e "\033[1;31m[\033[1;36m0\033[1;31m]\033[1;33m Volver al menГє principal\033[0m"
    echo ""
    echo -ne "\033[1;32mOpciГіn: \033[1;37m"
    read -r _op

    case "${_op:-}" in
        1)
            clear
            echo -e "\033[1;32mActivando limitador en tiempo realвЂ¦\033[0m"
            _redlibre_pam_remove
            _redlibre_rt_start
            echo -e "\033[1;32mListo. PAM del limitador desmontado en /etc/pam.d/sshd (si estaba); screen limiter iniciado.\033[0m"
            echo -e "\033[1;37mNo se ha reiniciado ni recargado sshd (no corta sesiones SSH actuales).\033[0m"
            echo -e "\033[1;37mEl servicio db-guardian no se ha modificado.\033[0m"
            echo -ne "\033[1;33m[ENTER]\033[0m "
            read -r
            ;;
        2)
            clear
            echo -e "\033[1;32mPreparando limitador PAM (se detiene el limitador en tiempo real)вЂ¦\033[0m"
            _redlibre_rt_stop
            _redlibre_install_pam_stack
            echo -e "\033[1;33mRevise mensajes anteriores. Reinicie SSH manualmente si el script lo indicГі.\033[0m"
            echo -ne "\033[1;33m[ENTER]\033[0m "
            read -r
            ;;
        3)
            clear
            echo -e "\033[1;31mDeteniendo limitadores de sesiГіn (screen y PAM)вЂ¦\033[0m"
            _redlibre_rt_stop
            _redlibre_pam_remove
            echo -e "\033[1;32mHecho: screen limiter parado y lГ­neas PAM del limitador eliminadas de /etc/pam.d/sshd.\033[0m"
            echo -e "\033[1;37mNo se ha reiniciado ni recargado sshd.\033[0m"
            echo -e "\033[1;37mdb-guardian no se ha detenido ni deshabilitado.\033[0m"
            echo -ne "\033[1;33m[ENTER]\033[0m "
            read -r
            ;;
        4)
            clear
            echo -e "\033[1;33mPAM y limitador en tiempo real pueden funcionar a la vez.\033[0m"
            echo -e "\033[1;37mвЂў PAM suele bloquear nuevas conexiones al superar el lГ­mite.\033[0m"
            echo -e "\033[1;37mвЂў El script en screen mata sesiones segГєn el log de auth (\033[1;33msecure\033[1;37m / \033[1;33mauth.log\033[1;37m); el conteo puede diferir del PAM.\033[0m"
            echo -e "\033[1;37mвЂў Use la misma \033[1;33musuarios.db\033[1;37m; con instalaciГіn В«completaВ» PAM lee la copia sincronizada por el guardiГЎn.\033[0m"
            echo -e "\033[1;33mSi no necesita redundancia, use solo la opciГіn 1 o 2.\033[0m"
            echo ""
            if ! _redlibre_pam_active; then
                echo -e "\033[1;32mInstalando / activando PAMвЂ¦\033[0m"
                _redlibre_install_pam_stack
            else
                echo -e "\033[1;37mPAM del limitador ya estaba configurado; no se reinstala.\033[0m"
            fi
            echo -e "\033[1;32mIniciando limitador en tiempo real (screen)вЂ¦\033[0m"
            _redlibre_rt_start
            echo -e "\033[1;32mListo: ambos mecanismos quedan activos si la instalaciГіn PAM tuvo Г©xito.\033[0m"
            echo -ne "\033[1;33m[ENTER]\033[0m "
            read -r
            ;;
        0 | 00)
            exit 0
            ;;
        *)
            echo -e "\033[1;31mOpciГіn no vГЎlida.\033[0m"
            sleep 2
            ;;
    esac
done
