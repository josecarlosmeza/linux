#!/bin/bash
#====================================================
# Gestión de revendedores — solo root
#====================================================
[[ $EUID -ne 0 ]] && {
    echo -e "\033[1;31mEjecute como root.\033[0m"
    exit 1
}

CMDS="/usr/bin/true,/bin/true,/bin/criarusuario-rev-root,/bin/criarteste-rev-root,/bin/remover-rev-root,/bin/alterarsenha-rev-root,/bin/mudardata-rev-root,/bin/alterarlimite-rev-root,/bin/infousers-rev-root,/bin/userbackup-rev-root"
SFILE="/etc/sudoers.d/redlibre-revendedores"

redlibre_rev_sudo_line() {
    local u="$1"
    printf '%s ALL=(root) NOPASSWD: %s\n' "$u" "$CMDS"
}

redlibre_rev_sync_sudo() {
    mkdir -p /etc/sudoers.d
    touch "$SFILE"
    chmod 440 "$SFILE"
    if command -v visudo >/dev/null 2>&1; then
        visudo -c -f "$SFILE" 2>/dev/null || true
    fi
}

redlibre_rev_remove_sudo() {
    local u="$1"
    [[ -f "$SFILE" ]] || return 0
    sed -i "/^${u} ALL=(root) NOPASSWD: /d" "$SFILE"
}

redlibre_rev_ssh_lock_apply() {
    if [[ -x /bin/revendedor-sshd-lock ]]; then
        /bin/revendedor-sshd-lock
    fi
}

clear
tput setaf 7
tput setab 4
tput bold
printf '%35s%s%-12s\n' "Gestión de revendedores RedLibre"
tput sgr0
echo ""
echo -e "\033[1;31m[\033[1;36m1\033[1;31m]\033[1;33m Crear o activar revendedor"
echo -e "\033[1;31m[\033[1;36m2\033[1;31m]\033[1;33m Listar revendedores"
echo -e "\033[1;31m[\033[1;36m3\033[1;31m]\033[1;33m Quitar revendedor"
echo -e "\033[1;31m[\033[1;36m4\033[1;31m]\033[1;33m Quitar revendedor y borrar usuario Linux"
echo -e "\033[1;31m[\033[1;36m5\033[1;31m]\033[1;33m Regenerar permisos sudo (todos)"
echo -e "\033[1;31m[\033[1;36m6\033[1;31m]\033[1;33m Editar límites / políticas de un revendedor"
echo -e "\033[1;31m[\033[1;36m0\033[1;31m]\033[1;33m Volver"
echo ""
echo -ne "\033[1;32mOpción: \033[1;37m"
read -r _m

case "$_m" in
    1)
        clear
        echo -ne "\033[1;32mNombre de usuario Linux del revendedor (minúsculas, sin espacios):\033[1;37m "
        read -r login
        [[ -z "$login" ]] && { echo -e "\033[1;31mVacío.\033[0m"; sleep 2; exit 0; }
        if ! [[ "$login" =~ ^[a-z][a-z0-9_-]{0,30}$ ]]; then
            echo -e "\033[1;31mNombre inválido.\033[0m"
            sleep 2
            exit 0
        fi
        if [[ -d "/etc/RedLibre/revendedores/$login" ]]; then
            echo -e "\033[1;33mYa existe revendedor «$login».\033[0m"
            sleep 2
            exit 0
        fi
        echo -ne "\033[1;32mContraseña del revendedor:\033[1;37m "
        read -r pass
        [[ ${#pass} -lt 4 ]] && { echo -e "\033[1;31mMínimo 4 caracteres.\033[0m"; sleep 2; exit 0; }
        echo -ne "\033[1;32mMáximo de cuentas SSH del revendedor (\033[1;33m0\033[1;32m = sin límite):\033[1;37m "
        read -r lim
        [[ "${lim//[^0-9]/}" = "" ]] && lim=0
        echo -ne "\033[1;32mUsuario prueba: duración en minutos:\033[1;37m "
        read -r pr_min
        [[ "${pr_min//[^0-9]/}" = "" ]] || [[ "$pr_min" -lt 1 ]] && pr_min=60
        echo -ne "\033[1;32mUsuario prueba: sesiones concurrentes por usuario:\033[1;37m "
        read -r pr_ses
        [[ "${pr_ses//[^0-9]/}" = "" ]] || [[ "$pr_ses" -lt 1 ]] && pr_ses=1
        echo -ne "\033[1;32mMáx. sesiones concurrentes por usuario normal (\033[1;33m0\033[1;32m = sin tope):\033[1;37m "
        read -r max_u
        [[ "${max_u//[^0-9]/}" = "" ]] && max_u=0
        echo -ne "\033[1;32mMáx. sesiones SSH en total (todos sus clientes; \033[1;33m0\033[1;32m = sin tope):\033[1;37m "
        read -r max_t
        [[ "${max_t//[^0-9]/}" = "" ]] && max_t=0

        if id "$login" &>/dev/null; then
            echo -e "\033[1;33mEl usuario «$login» ya existe en el sistema; se añadirá el rol revendedor.\033[0m"
        else
            if ! useradd -m -s /bin/bash "$login" 2>/dev/null; then
                echo -e "\033[1;31mNo se pudo crear el usuario.\033[0m"
                sleep 2
                exit 0
            fi
        fi
        echo "$login:$pass" | chpasswd
        getent group redlibre-rev >/dev/null 2>&1 || groupadd -r redlibre-rev 2>/dev/null || groupadd redlibre-rev
        usermod -aG redlibre-rev "$login" 2>/dev/null || true
        [[ -d "/home/$login" ]] && chmod 750 "/home/$login" 2>/dev/null || true

        mkdir -p "/etc/RedLibre/revendedores/$login/usuarios"
        {
            echo "LIMITE_USUARIOS=$lim"
            echo "PRUEBA_MINUTOS=$pr_min"
            echo "PRUEBA_SESIONES=$pr_ses"
            echo "MAX_SESIONES_POR_USUARIO=$max_u"
            echo "MAX_SESIONES_TOTAL_REVENDEDOR=$max_t"
            echo "# Creado $(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date)"
        } >"/etc/RedLibre/revendedores/$login/conf"
        chmod 644 "/etc/RedLibre/revendedores/$login/conf" 2>/dev/null || true

        mkdir -p /etc/sudoers.d
        touch "$SFILE"
        redlibre_rev_remove_sudo "$login"
        redlibre_rev_sudo_line "$login" >>"$SFILE"
        chmod 440 "$SFILE"
        redlibre_rev_sync_sudo
        redlibre_rev_ssh_lock_apply

        _brc="/home/$login/.bashrc"
        if [[ -f "$_brc" ]] && ! grep -q 'menu-revendedor' "$_brc" 2>/dev/null; then
            {
                echo ""
                echo "# RedLibre — panel revendedor al iniciar sesión SSH"
                echo "if [[ \$- == *i* ]] && [[ -t 0 ]]; then /bin/menu-revendedor; fi"
            } >> "$_brc"
        fi

        echo ""
        echo -e "\033[1;32mRevendedor «$login» configurado.\033[0m"
        echo -e "\033[1;37m• Conéctese por SSH; se abrirá el panel de revendedor.\033[0m"
        echo -e "\033[1;37m• SSH: \033[1;33msin shell remoto\033[1;37m (solo este panel; no \033[1;33mssh usuario comando\033[1;37m ni scp).\033[0m"
        echo ""
        echo -ne "\033[1;33m[ENTER]\033[0m"
        read -r
        ;;
    2)
        clear
        echo -e "\033[1;33mRevendedores registrados:\033[0m"
        echo ""
        if [[ ! -d /etc/RedLibre/revendedores ]]; then
            echo "(ninguno)"
        else
            shopt -s nullglob
            for d in /etc/RedLibre/revendedores/*/; do
                [[ -d "$d" ]] || continue
                b=$(basename "$d")
                _c=$(find "$d/usuarios" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l)
                _lm="0"
                _pm="60"
                _ps="1"
                _mxu="0"
                _mxt="0"
                [[ -f "$d/conf" ]] && {
                    _lm=$(grep -E '^LIMITE_USUARIOS=' "$d/conf" | head -1 | cut -d= -f2)
                    _pm=$(grep -E '^PRUEBA_MINUTOS=' "$d/conf" | head -1 | cut -d= -f2)
                    _ps=$(grep -E '^PRUEBA_SESIONES=' "$d/conf" | head -1 | cut -d= -f2)
                    _mxu=$(grep -E '^MAX_SESIONES_POR_USUARIO=' "$d/conf" | head -1 | cut -d= -f2)
                    _mxt=$(grep -E '^MAX_SESIONES_TOTAL_REVENDEDOR=' "$d/conf" | head -1 | cut -d= -f2)
                }
                echo -e " \033[1;32m$b\033[0m — cuentas: \033[1;37m$_c\033[0m / \033[1;37m${_lm:-0}\033[0m — prueba: \033[1;37m${_pm:-60}\033[0m min / \033[1;37m${_ps:-1}\033[0m ses. — tope/usr: \033[1;37m${_mxu:-0}\033[0m — tope total: \033[1;37m${_mxt:-0}\033[0m"
            done
            shopt -u nullglob
        fi
        echo ""
        echo -ne "\033[1;33m[ENTER]\033[0m"
        read -r
        ;;
    3|4)
        clear
        echo -ne "\033[1;32mUsuario revendedor a quitar:\033[1;37m "
        read -r login
        [[ -z "$login" || ! -d "/etc/RedLibre/revendedores/$login" ]] && {
            echo -e "\033[1;31mNo existe ese revendedor.\033[0m"
            sleep 2
            exit 0
        }
        _nu=$(find "/etc/RedLibre/revendedores/$login/usuarios" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | wc -l)
        if [[ "$_nu" -gt 0 ]]; then
            echo -e "\033[1;33mEste revendedor tiene \033[1;37m$_nu\033[1;33m usuario(s) SSH.\033[0m"
            echo -ne "¿Eliminar esos usuarios SSH del sistema? \033[1;37m[s/N]: \033[0m"
            read -r ok
            if [[ "$ok" = "s" || "$ok" = "S" ]]; then
                for uf in "/etc/RedLibre/revendedores/$login/usuarios"/*; do
                    [[ -f "$uf" ]] || continue
                    ussh=$(basename "$uf")
                    pkill -f "$ussh" >/dev/null 2>&1
                    userdel --force "$ussh" >/dev/null 2>&1
                    grep -v "^${ussh}[[:space:]]" /root/usuarios.db > /tmp/udbr && mv /tmp/udbr /root/usuarios.db
                    rm -f "/etc/RedLibre/senha/$ussh"
                done
            else
                echo -e "\033[1;31mCancelado.\033[0m"
                sleep 2
                exit 0
            fi
        fi
        gpasswd -d "$login" redlibre-rev 2>/dev/null || true
        redlibre_rev_remove_sudo "$login"
        rm -rf "/etc/RedLibre/revendedores/$login"
        if [[ "$_m" = "4" ]]; then
            userdel -r "$login" 2>/dev/null || userdel "$login" 2>/dev/null
            echo -e "\033[1;32mRevendedor y usuario Linux «$login» eliminados.\033[0m"
        else
            echo -e "\033[1;32mRevendedor «$login» eliminado (usuario Linux conservado). Use la opción 4 para borrarlo también.\033[0m"
        fi
        redlibre_rev_ssh_lock_apply
        echo ""
        echo -ne "\033[1;33m[ENTER]\033[0m"
        read -r
        ;;
    6)
        clear
        echo -ne "\033[1;32mUsuario revendedor a editar:\033[1;37m "
        read -r login
        [[ -z "$login" || ! -d "/etc/RedLibre/revendedores/$login" ]] && {
            echo -e "\033[1;31mNo existe ese revendedor.\033[0m"
            sleep 2
            exit 0
        }
        _cf="/etc/RedLibre/revendedores/$login/conf"
        _lim=$(grep -E '^LIMITE_USUARIOS=' "$_cf" 2>/dev/null | head -1 | cut -d= -f2)
        _pm=$(grep -E '^PRUEBA_MINUTOS=' "$_cf" 2>/dev/null | head -1 | cut -d= -f2)
        _ps=$(grep -E '^PRUEBA_SESIONES=' "$_cf" 2>/dev/null | head -1 | cut -d= -f2)
        _mxu=$(grep -E '^MAX_SESIONES_POR_USUARIO=' "$_cf" 2>/dev/null | head -1 | cut -d= -f2)
        _mxt=$(grep -E '^MAX_SESIONES_TOTAL_REVENDEDOR=' "$_cf" 2>/dev/null | head -1 | cut -d= -f2)
        [[ "${_lim//[^0-9]/}" = "" ]] && _lim=0
        [[ "${_pm//[^0-9]/}" = "" ]] || [[ "$_pm" -lt 1 ]] && _pm=60
        [[ "${_ps//[^0-9]/}" = "" ]] || [[ "$_ps" -lt 1 ]] && _ps=1
        [[ "${_mxu//[^0-9]/}" = "" ]] && _mxu=0
        [[ "${_mxt//[^0-9]/}" = "" ]] && _mxt=0
        echo ""
        echo -e "\033[1;33mValores actuales de «$login». Enter deja el valor actual.\033[0m"
        echo -ne "\033[1;32mMáx. cuentas SSH [\033[1;37m$_lim\033[1;32m]:\033[1;37m "
        read -r r
        [[ -n "${r//[^0-9]/}" ]] && lim="$r" || lim="$_lim"
        [[ "${lim//[^0-9]/}" = "" ]] && lim=0
        echo -ne "\033[1;32mPrueba: minutos [\033[1;37m$_pm\033[1;32m]:\033[1;37m "
        read -r r
        [[ -n "${r//[^0-9]/}" ]] && pr_min="$r" || pr_min="$_pm"
        [[ "$pr_min" -lt 1 ]] 2>/dev/null && pr_min=60
        echo -ne "\033[1;32mPrueba: sesiones [\033[1;37m$_ps\033[1;32m]:\033[1;37m "
        read -r r
        [[ -n "${r//[^0-9]/}" ]] && pr_ses="$r" || pr_ses="$_ps"
        [[ "$pr_ses" -lt 1 ]] 2>/dev/null && pr_ses=1
        echo -ne "\033[1;32mMáx. sesiones/usuario normal [\033[1;37m$_mxu\033[1;32m]:\033[1;37m "
        read -r r
        [[ -n "${r//[^0-9]/}" ]] && max_u="$r" || max_u="$_mxu"
        [[ "${max_u//[^0-9]/}" = "" ]] && max_u=0
        echo -ne "\033[1;32mMáx. sesiones totales [\033[1;37m$_mxt\033[1;32m]:\033[1;37m "
        read -r r
        [[ -n "${r//[^0-9]/}" ]] && max_t="$r" || max_t="$_mxt"
        [[ "${max_t//[^0-9]/}" = "" ]] && max_t=0
        _com=$(grep -v -E '^(LIMITE_USUARIOS|PRUEBA_MINUTOS|PRUEBA_SESIONES|MAX_SESIONES_POR_USUARIO|MAX_SESIONES_TOTAL_REVENDEDOR)=' "$_cf" 2>/dev/null)
        {
            echo "LIMITE_USUARIOS=$lim"
            echo "PRUEBA_MINUTOS=$pr_min"
            echo "PRUEBA_SESIONES=$pr_ses"
            echo "MAX_SESIONES_POR_USUARIO=$max_u"
            echo "MAX_SESIONES_TOTAL_REVENDEDOR=$max_t"
            [[ -n "$_com" ]] && printf '%s\n' "$_com"
        } >"$_cf"
        chmod 644 "$_cf" 2>/dev/null || true
        echo -e "\033[1;32mPolítica actualizada para «$login».\033[0m"
        echo ""
        echo -ne "\033[1;33m[ENTER]\033[0m"
        read -r
        ;;
    5)
        clear
        _tmpf=$(mktemp)
        shopt -s nullglob
        for _d in /etc/RedLibre/revendedores/*; do
            [[ -d "$_d" ]] || continue
            _ru=$(basename "$_d")
            redlibre_rev_sudo_line "$_ru" >>"$_tmpf"
        done
        shopt -u nullglob
        if [[ ! -s "$_tmpf" ]]; then
            rm -f "$_tmpf"
            echo -e "\033[1;33mNo hay revendedores registrados.\033[0m"
        else
            mkdir -p /etc/sudoers.d
            mv "$_tmpf" "$SFILE"
            chmod 440 "$SFILE"
            redlibre_rev_sync_sudo
            shopt -s nullglob
            for _cf in /etc/RedLibre/revendedores/*/conf; do
                [[ -f "$_cf" ]] && chmod 644 "$_cf" 2>/dev/null
            done
            shopt -u nullglob
            echo -e "\033[1;32mArchivo sudo actualizado para todos los revendedores (\033[1;33m$SFILE\033[1;32m).\033[0m"
        fi
        redlibre_rev_ssh_lock_apply
        echo ""
        echo -ne "\033[1;33m[ENTER]\033[0m"
        read -r
        ;;
    0|00|"")
        exit 0
        ;;
    *)
        echo -e "\033[1;31mOpción no válida.\033[0m"
        sleep 1
        ;;
esac

exit 0
