#!/bin/bash

[[ -f /etc/RedLibre/redlibre-vence-common ]] && . /etc/RedLibre/redlibre-vence-common

# Limpiar pantalla y mostrar lista general
clear
echo -e "\E[44;1;37m Usuario         ContraseГ±a       Limite      Fecha expiraciГіn  \E[0m"
echo ""

# Lista General
for users in $(awk -F : '$3 >= 1000 { print $1 }' /etc/passwd | sort | grep -v "nobody")
do
    # LГіgica de LГ­mite
    [[ $(grep -cw "$users" $HOME/usuarios.db) == "1" ]] && lim=$(grep -w "$users" $HOME/usuarios.db | cut -d' ' -f2) || lim="1"

    # LГіgica de ContraseГ±a
    [[ -e "/etc/RedLibre/senha/$users" ]] && senha=$(cat "/etc/RedLibre/senha/$users") || senha="Null"

    # Conteo de procesos del usuario
    conexiones=$(ps -u "$users" | grep -c sshd)

    # Fecha/hora: preferir vence
    if declare -F redlibre_vence_display_info >/dev/null 2>&1; then
        IFS='|' read -r fecha_venc exp_sec _modo <<<"$(redlibre_vence_display_info "$users")"
    else
        datauser=$(LANG=en_US.UTF-8 chage -l "$users" 2>/dev/null | grep "Account expires" | awk -F': ' '{print $2}' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        if [[ -z "$datauser" || "$datauser" == "never" ]]; then
            fecha_venc="Nunca"; exp_sec=""; _modo="never"
        else
            fecha_venc=$(date --date="$datauser" '+%d/%m/%Y' 2>/dev/null || date -d "$datauser" '+%d/%m/%Y' 2>/dev/null)
            exp_sec=$(date +%s --date="$datauser" 2>/dev/null || date +%s -d "$datauser" 2>/dev/null)
            _modo="chage"
        fi
    fi
    if [[ "$_modo" == "never" || "$fecha_venc" == "Nunca" ]]; then
        data="\033[1;33mNunca\033[0m"
    else
        now_sec=$(date +%s)
        if [[ -n "$exp_sec" && "$exp_sec" != "0" ]]; then
            if [[ $now_sec -ge $exp_sec ]]; then
                data="\033[1;31m$fecha_venc (Expirado)\033[0m"
            else
                dias=$(( (exp_sec - now_sec) / 86400 ))
                if [[ "$_modo" == "vence" ]]; then
                    data="\033[1;32m$fecha_venc ($dias d В· В±2 min)\033[0m"
                else
                    data="\033[1;32m$fecha_venc ($dias dГ­as)\033[0m"
                fi
            fi
        else
            data="\033[1;37m$fecha_venc\033[0m"
        fi
    fi

    # Formateo visual
    if [[ "$conexiones" -gt "0" ]]; then
        Usuario=$(printf ' %-15s' "$users ($conexiones)")
    else
        Usuario=$(printf ' %-15s' "$users")
    fi
    
    Senha=$(printf '%-13s' "$senha")
    Limite=$(printf '%-10s' "$lim")

    echo -e "\033[1;33m$Usuario \033[1;37m$Senha \033[1;37m$Limite \033[1;37m$data\033[0m"
    echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
done

# Resumen inferior
_tuser=$(awk -F: '$3>=1000 {print $1}' /etc/passwd | grep -v nobody | wc -l)
_onli=$(ps aux | grep sshd | grep -v root | grep -v grep | wc -l)
echo -e "\n\033[1;33mвЂў \033[1;36mTOTAL USUARIOS:\033[1;37m $_tuser  \033[1;33mвЂў \033[1;32mVPN ONLINE:\033[1;37m $_onli \033[1;33mвЂў\033[0m\n"

# --- SECCIГ“N DE INTERACCIГ“N ---
echo -ne "\033[1;37mEscriba un nombre para detalles o [\033[1;32mEnter\033[1;37m] para salir: \033[1;33m"
read -r selection

if [[ -n "$selection" ]]; then
    if id "$selection" >/dev/null 2>&1; then
        clear
        echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
        echo -e "\E[44;1;37m        DETALLES DE CONEXIГ“N VPN: $selection      \E[0m"
        echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
        
        # Conteo y Tiempo de conexiГіn
        d_conexiones=$(ps -u "$selection" -o comm,etime | grep sshd | awk '{print $2}')
        num_con=$(echo "$d_conexiones" | wc -w)
        
        if [[ $num_con -gt 0 ]]; then
            d_estado="\033[1;32mCONECTADO\033[0m"
            tiempos=$(echo "$d_conexiones" | xargs | sed 's/ / | /g')
        else
            d_estado="\033[1;31mDESCONECTADO\033[0m"
            tiempos="N/A"
        fi

        [[ -e /etc/RedLibre/senha/$selection ]] && d_pass=$(cat /etc/RedLibre/senha/$selection) || d_pass="Null"
        if declare -F redlibre_vence_display_info >/dev/null 2>&1; then
            IFS='|' read -r d_val _de _dm <<<"$(redlibre_vence_display_info "$selection")"
            [[ "$_dm" == "vence" ]] && d_val="$d_val (В±2 min)"
        else
            d_val_raw=$(LANG=en_US.UTF-8 chage -l "$selection" 2>/dev/null | grep "Account expires" | awk -F': ' '{print $2}' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
            if [[ -z "$d_val_raw" || "$d_val_raw" == "never" ]]; then
                d_val="Nunca"
            else
                d_val=$(date --date="$d_val_raw" '+%d/%m/%Y' 2>/dev/null || date -d "$d_val_raw" '+%d/%m/%Y' 2>/dev/null)
                [[ -z "$d_val" ]] && d_val="$d_val_raw"
            fi
        fi

        echo -e "\033[1;36m USUARIO:     \033[1;37m$selection"
        echo -e "\033[1;36m ESTADO VPN:  $d_estado"
        echo -e "\033[1;36m SESIONES:    \033[1;37m$num_con activa(s)"
        echo -e "\033[1;36m TIEMPO/S:    \033[1;33m$tiempos (H:M:S)"
        echo -e "\033[1;36m CONTRASEГ‘A:  \033[1;37m$d_pass"
        echo -e "\033[1;36m VENCIMIENTO: \033[1;37m$d_val"
        echo -e "\033[0;34mв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\033[0m"
        echo ""
        read -p "Presione [Enter] para salir..."
    else
        echo -e "\n\033[1;31mError: El usuario '$selection' no existe.\033[0m"
        sleep 2
    
    fi
fi
clear
