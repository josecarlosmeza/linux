#!/bin/bash
#====================================================
# Usuario de prueba — revendedor (sudo). Elige duración y sesiones dentro del tope del admin.
# Lectura por /dev/tty si hace falta (sudo+SSH). Fallbacks si common está incompleto.
#====================================================
[[ -f /etc/RedLibre/redlibre-rev-common ]] && . /etc/RedLibre/redlibre-rev-common || exit 1

if ! declare -F redlibre_rev_valid_login_name >/dev/null 2>&1; then
    redlibre_rev_valid_login_name() {
        local u="$1"
        [[ -n "$u" ]] || return 1
        [[ ${#u} -gt 3 ]] || return 1
        [[ "$u" =~ ^[a-zA-Z0-9]+$ ]] || return 1
        return 0
    }
fi
if ! declare -F redlibre_rev_register_user >/dev/null 2>&1; then
    redlibre_rev_register_user() {
        local u="$1"
        mkdir -p "/etc/RedLibre/revendedores/$REV/usuarios"
        : >"/etc/RedLibre/revendedores/$REV/usuarios/$u"
    }
fi
if ! declare -F redlibre_rev_set_password_plain >/dev/null 2>&1; then
    redlibre_rev_set_password_plain() {
        local u="$1" p="$2" h
        [[ -n "$u" && -n "$p" ]] || return 1
        id "$u" &>/dev/null || return 1
        if printf '%s\n' "${u}:${p}" | chpasswd 2>/dev/null; then
            return 0
        fi
        if command -v openssl >/dev/null 2>&1; then
            h=$(printf '%s\n' "$p" | openssl passwd -6 -stdin 2>/dev/null) || h=""
            if [[ -z "$h" ]]; then
                h=$(openssl passwd -6 "$p" 2>/dev/null) || h=""
            fi
            if [[ -n "$h" ]] && usermod -p "$h" "$u" 2>/dev/null; then
                return 0
            fi
        fi
        return 1
    }
fi
if ! declare -F redlibre_rev_prueba_minutos >/dev/null 2>&1; then
    redlibre_rev_prueba_minutos() { echo "60"; }
fi
if ! declare -F redlibre_rev_prueba_sesiones >/dev/null 2>&1; then
    redlibre_rev_prueba_sesiones() { echo "1"; }
fi
if ! declare -F redlibre_rev_max_sesiones_usuario >/dev/null 2>&1; then
    redlibre_rev_max_sesiones_usuario() { echo "0"; }
fi

redlibre_rev_init

_redlibre_read_tty() {
    if [[ -r /dev/tty ]]; then
        read -r "$@" < /dev/tty
    else
        read -r "$@"
    fi
}

_redlibre_strip_input() {
    local s="$1"
    s="${s//$'\r'/}"
    s="${s#"${s%%[![:space:]]*}"}"
    s="${s%"${s##*[![:space:]]}"}"
    printf '%s' "$s"
}

IP=$(cat /etc/IP 2>/dev/null || echo "—")
TEST_DIR="/etc/RedLibre/userteste"
DB_FILE="/root/usuarios.db"
PASS_DIR="/etc/RedLibre/senha"
NOLOGIN_SHELL="/usr/sbin/nologin"
[[ -x "$NOLOGIN_SHELL" ]] || NOLOGIN_SHELL="/sbin/nologin"

_max_min=$(redlibre_rev_prueba_minutos)
_max_ses_prueba=$(redlibre_rev_prueba_sesiones)
_max_min="${_max_min//[[:space:]]/}"
_max_ses_prueba="${_max_ses_prueba//[[:space:]]/}"
[[ -z "$_max_min" || "$_max_min" -lt 1 ]] && _max_min=60
[[ -z "$_max_ses_prueba" || "$_max_ses_prueba" -lt 1 ]] && _max_ses_prueba=1

_cap_u=$(redlibre_rev_max_sesiones_usuario)
_cap_u="${_cap_u//[[:space:]]/}"
[[ -z "$_cap_u" ]] && _cap_u=0
_max_ses_eff="$_max_ses_prueba"
if [[ "$_cap_u" -gt 0 ]] && [[ "$_max_ses_eff" -gt "$_cap_u" ]]; then
    _max_ses_eff="$_cap_u"
fi
[[ "$_max_ses_eff" -lt 1 ]] && _max_ses_eff=1

error_exit() {
    echo ""
    tput setaf 7
    tput setab 1
    tput bold
    echo "" ; echo "ERROR: $1" ; echo ""
    tput sgr0
    if [[ -n "${nome:-}" ]] && id -u "$nome" &>/dev/null; then
        userdel --force "$nome" >/dev/null 2>&1
        sed -i.bak "/^${nome}[[:space:]]/d" "$DB_FILE" 2>/dev/null
        rm -f "$PASS_DIR/$nome" "${TEST_DIR}/${nome}.sh" 2>/dev/null
        rm -f "/etc/RedLibre/revendedores/$REV/usuarios/$nome" 2>/dev/null
    fi
    echo -ne "\033[1;33mPulse [ENTER] para volver al menú...\033[0m"
    if [[ -r /dev/tty ]]; then
        read -r < /dev/tty
    else
        read -r
    fi
    exit 1
}

if ! systemctl is-active --quiet atd 2>/dev/null; then
    echo -e "\033[1;33mIntentando activar atd...\033[0m"
    systemctl enable --now atd >/dev/null 2>&1 || error_exit "Active atd: systemctl enable --now atd (instale el paquete 'at')."
fi

_lim=$(redlibre_rev_limit)
_cnt=$(redlibre_rev_count_owned)
_lim="${_lim//[[:space:]]/}"
_cnt="${_cnt//[[:space:]]/}"
[[ -z "$_lim" ]] && _lim=0
[[ -z "$_cnt" ]] && _cnt=0
if [[ "$_lim" -gt 0 ]] && [[ "$_cnt" -ge "$_lim" ]]; then
    echo -e "\n\033[41;1;37m Límite de usuarios alcanzado ($_lim). \033[0m\n"
    echo -ne "\033[1;33mPulse [ENTER] para volver al menú...\033[0m"
    if [[ -r /dev/tty ]]; then read -r < /dev/tty; else read -r; fi
    exit 1
fi

mkdir -p "$TEST_DIR" "$PASS_DIR"

clear
tput setaf 7
tput setab 4
tput bold
printf '%32s%s%-10s\n' "Usuario de prueba (revendedor)"
tput sgr0
echo ""
echo -e "\033[1;36mTope del administrador (no puede superarlo):\033[0m"
echo -e "  • Hasta \033[1;37m$_max_min\033[0m minutos de duración"
echo -e "  • Hasta \033[1;37m$_max_ses_eff\033[0m sesión(es) concurrente(s)"
if [[ "$_cap_u" -gt 0 ]] && [[ "$_max_ses_eff" -lt "$_max_ses_prueba" ]]; then
    echo -e "\033[1;33m  (Sesiones acotadas por MAX_SESIONES_POR_USUARIO=$_cap_u frente a PRUEBA_SESIONES=$_max_ses_prueba).\033[0m"
fi
echo ""

if [[ "$(find "$TEST_DIR" -maxdepth 1 -name '*.sh' -print -quit 2>/dev/null)" ]]; then
    echo -e "\033[1;32mHay usuarios de prueba con borrado programado en el servidor.\033[0m"
else
    echo -e "\033[1;33m(Ningún script de prueba pendiente en el servidor.)\033[0m"
fi
echo ""
echo -ne "\033[1;32mNombre del usuario:\033[1;37m "
_redlibre_read_tty nome
nome=$(_redlibre_strip_input "$nome")
[[ -z "$nome" ]] && error_exit "Nombre vacío (¿consola/TTY?)."
if ! redlibre_rev_valid_login_name "$nome"; then
    error_exit "Nombre inválido: mínimo 4 caracteres y solo letras y números (sin símbolos)."
fi
if id -u "$nome" &>/dev/null; then
    error_exit "Ese usuario ya existe."
fi

echo -ne "\033[1;32mContraseña:\033[1;37m "
_redlibre_read_tty pass
pass=$(_redlibre_strip_input "$pass")
[[ -z "$pass" ]] && error_exit "Contraseña vacía."

echo ""
echo -ne "\033[1;32mDuración en minutos \033[1;37m(1–$_max_min)\033[1;32m:\033[1;37m "
_redlibre_read_tty u_temp
u_temp=$(_redlibre_strip_input "$u_temp")
if ! [[ "$u_temp" =~ ^[0-9]+$ ]] || [[ "$u_temp" -lt 1 ]] || [[ "$u_temp" -gt "$_max_min" ]]; then
    error_exit "Minutos inválidos: use un entero entre 1 y $_max_min."
fi

echo -ne "\033[1;32mSesiones concurrentes \033[1;37m(1–$_max_ses_eff)\033[1;32m:\033[1;37m "
_redlibre_read_tty limit
limit=$(_redlibre_strip_input "$limit")
if ! [[ "$limit" =~ ^[0-9]+$ ]] || [[ "$limit" -lt 1 ]] || [[ "$limit" -gt "$_max_ses_eff" ]]; then
    error_exit "Sesiones inválidas: use un entero entre 1 y $_max_ses_eff."
fi

if ! useradd -M -s "$NOLOGIN_SHELL" "$nome"; then
    error_exit "No se pudo crear el usuario."
fi

if ! redlibre_rev_set_password_plain "$nome" "$pass"; then
    error_exit "No se pudo establecer la contraseña (chpasswd/openssl)."
fi
echo "$pass" >"$PASS_DIR/$nome"
echo "$nome $limit" >>"$DB_FILE"
redlibre_rev_register_user "$nome"

DELETE_SCRIPT="$TEST_DIR/${nome}.sh"

cat << EOF >"$DELETE_SCRIPT"
#!/bin/bash
pkill -u "$nome" 2>/dev/null
userdel --force "$nome" >/dev/null 2>&1
sed -i.bak '/^${nome}[[:space:]]/d' "$DB_FILE" >/dev/null 2>&1
rm -f "$PASS_DIR/$nome" "$DELETE_SCRIPT" >/dev/null 2>&1
rm -f "/etc/RedLibre/revendedores/$REV/usuarios/$nome" >/dev/null 2>&1
exit
EOF

chmod 700 "$DELETE_SCRIPT"
at_output=$(at -f "$DELETE_SCRIPT" "now + $u_temp min" 2>&1) || error_exit "No se pudo programar 'at': $at_output"

clear
echo -e "\E[44;1;37m     Usuario de prueba creado   \E[0m"
echo ""
echo -e "\033[1;32mIP:\033[1;37m $IP"
echo -e "\033[1;32mUsuario:\033[1;37m $nome"
echo -e "\033[1;32mContraseña:\033[1;37m $pass"
echo -e "\033[1;32mLímite sesiones:\033[1;37m $limit \033[0m(tope admin $_max_ses_eff)"
echo -e "\033[1;32mVálido:\033[1;37m $u_temp \033[0mmin (tope admin $_max_min min)"
echo ""
echo -e "\033[1;37m$nome:$pass\033[0m"
echo ""
echo -e "\033[1;33mTras ese tiempo el usuario se eliminará solo.\033[0m"
echo -ne "\033[1;33m[ENTER]\033[0m"
_redlibre_read_tty _
exit 0
