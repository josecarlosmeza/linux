#!/bin/bash
#====================================================
# Usuario de prueba — revendedor (sudo). Duración y sesiones: conf del admin.
#====================================================
[[ -f /etc/RedLibre/redlibre-rev-common ]] && . /etc/RedLibre/redlibre-rev-common || exit 1
redlibre_rev_init

IP=$(cat /etc/IP 2>/dev/null || echo "—")
TEST_DIR="/etc/RedLibre/userteste"
DB_FILE="/root/usuarios.db"
PASS_DIR="/etc/RedLibre/senha"
NOLOGIN_SHELL="/usr/sbin/nologin"
[[ -x "$NOLOGIN_SHELL" ]] || NOLOGIN_SHELL="/sbin/nologin"

_pr_min=$(redlibre_rev_prueba_minutos)
_pr_ses=$(redlibre_rev_prueba_sesiones)

error_exit() {
    echo ""
    tput setaf 7
    tput setab 1
    tput bold
    echo "" ; echo "ERROR: $1" ; echo ""
    tput sgr0
    if [[ -n "${nome:-}" ]] && id -u "$nome" &>/dev/null; then
        userdel --force "$nome" >/dev/null 2>&1
        sed -i.bak "/^${nome}[[:space:]]/d" "$DB_FILE" 2>/dev/null
        rm -f "$PASS_DIR/$nome" "${TEST_DIR}/${nome}.sh" 2>/dev/null
        rm -f "/etc/RedLibre/revendedores/$REV/usuarios/$nome" 2>/dev/null
    fi
    exit 1
}

if ! systemctl is-active --quiet atd 2>/dev/null; then
    echo -e "\033[1;33mIntentando activar atd...\033[0m"
    systemctl enable --now atd >/dev/null 2>&1 || error_exit "Active atd: systemctl enable --now atd (instale el paquete 'at')."
fi

_lim=$(redlibre_rev_limit)
_cnt=$(redlibre_rev_count_owned)
if [[ "$_lim" -gt 0 ]] && [[ "$_cnt" -ge "$_lim" ]]; then
    echo -e "\n\033[41;1;37m Límite de usuarios alcanzado ($_lim). \033[0m\n"
    exit 1
fi

mkdir -p "$TEST_DIR" "$PASS_DIR"

clear
tput setaf 7
tput setab 4
tput bold
printf '%32s%s%-10s\n' "Usuario de prueba (revendedor)"
tput sgr0
echo ""
echo -e "\033[1;36mPolítica del administrador:\033[0m duración \033[1;37m$_pr_min\033[0m min, \033[1;37m$_pr_ses\033[0m sesión(es) concurrente(s)."
echo ""

if [[ "$(find "$TEST_DIR" -maxdepth 1 -name '*.sh' -print -quit 2>/dev/null)" ]]; then
    echo -e "\033[1;32mHay usuarios de prueba con borrado programado en el servidor.\033[0m"
else
    echo -e "\033[1;33m(Ningún script de prueba pendiente en el servidor.)\033[0m"
fi
echo ""
echo -ne "\033[1;32mNombre del usuario:\033[1;37m "
read -r nome
[[ -z "$nome" ]] && error_exit "Nombre vacío."
if ! redlibre_rev_valid_login_name "$nome"; then
    error_exit "Nombre inválido: más de 3 caracteres y solo letras y números (sin símbolos)."
fi
if id -u "$nome" &>/dev/null; then
    error_exit "Ese usuario ya existe."
fi

echo -ne "\033[1;32mContraseña:\033[1;37m "
read -r pass
[[ -z "$pass" ]] && error_exit "Contraseña vacía."

limit="$_pr_ses"
u_temp="$_pr_min"

if ! useradd -M -s "$NOLOGIN_SHELL" "$nome"; then
    error_exit "No se pudo crear el usuario."
fi

echo "$nome:$pass" | chpasswd
echo "$pass" >"$PASS_DIR/$nome"
echo "$nome $limit" >>"$DB_FILE"
redlibre_rev_register_user "$nome"

DELETE_SCRIPT="$TEST_DIR/${nome}.sh"

cat << EOF >"$DELETE_SCRIPT"
#!/bin/bash
pkill -u "$nome" 2>/dev/null
userdel --force "$nome" >/dev/null 2>&1
sed -i.bak '/^${nome}[[:space:]]/d' "$DB_FILE" >/dev/null 2>&1
rm -f "$PASS_DIR/$nome" "$DELETE_SCRIPT" >/dev/null 2>&1
rm -f "/etc/RedLibre/revendedores/$REV/usuarios/$nome" >/dev/null 2>&1
exit
EOF

chmod 700 "$DELETE_SCRIPT"
at_output=$(at -f "$DELETE_SCRIPT" "now + $u_temp min" 2>&1) || error_exit "No se pudo programar 'at': $at_output"

clear
echo -e "\E[44;1;37m     Usuario de prueba creado   \E[0m"
echo ""
echo -e "\033[1;32mIP:\033[1;37m $IP"
echo -e "\033[1;32mUsuario:\033[1;37m $nome"
echo -e "\033[1;32mContraseña:\033[1;37m $pass"
echo -e "\033[1;32mLímite sesiones:\033[1;37m $limit \033[0m(admin)"
echo -e "\033[1;32mVálido:\033[1;37m $u_temp \033[0mmin (admin)"
echo ""
echo -e "\033[1;37m$nome:$pass\033[0m"
echo ""
echo -e "\033[1;33mTras ese tiempo el usuario se eliminará solo.\033[0m"
echo -ne "\033[1;33m[ENTER]\033[0m"
read -r
exit 0
