#!/bin/bash
[[ -f /etc/RedLibre/redlibre-rev-common ]] && . /etc/RedLibre/redlibre-rev-common || exit 1
redlibre_rev_init

clear
tput setaf 7
tput setab 4
tput bold
printf '%38s%s%-8s\n' " Usuarios conectados (sus clientes) "
tput sgr0
echo ""

_total=0
while read -r users; do
    [[ -z "$users" ]] && continue
    _c=$(ps -u "$users" 2>/dev/null | grep -c sshd || true)
    [[ "${_c:-0}" -gt 0 ]] && _total=$((_total + 1))
done <<< "$(redlibre_rev_list_owned)"

echo -e "\033[1;36m  Total de usuarios con conexión SSH activa:\033[0m"
echo ""
echo -e "  \033[1;32m$_total\033[0m"
echo ""
echo -e "\033[1;33m  (Cuenta solo sus usuarios con al menos una sesión abierta.)\033[0m"
echo ""
echo -ne "\033[1;33mPresione [ENTER] para volver...\033[0m"
read -r

exit 0
