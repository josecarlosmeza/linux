#!/bin/bash
[[ -f /etc/RedLibre/redlibre-rev-common ]] && . /etc/RedLibre/redlibre-rev-common || exit 1
redlibre_rev_init

tput setaf 7
tput setab 4
tput bold
printf '%35s%s%-10s\n' "Cambiar contraseña (revendedor)"
tput sgr0
echo ""

_userT=$(redlibre_rev_list_owned)
if [[ -z "$_userT" ]]; then
    echo -e "\033[1;31mNo tiene usuarios.\033[0m"
    sleep 2
    exit 0
fi

echo -e "\033[1;33mSUS USUARIOS:\033[0m"
echo ""
i=0
unset _userPass
while read -r _user; do
    [[ -z "$_user" ]] && continue
    i=$((i + 1))
    if [[ $i -lt 10 ]]; then i_display="0$i"; else i_display="$i"; fi
    if [[ -e "/etc/RedLibre/senha/$_user" ]]; then
        _senha="$(cat "/etc/RedLibre/senha/$_user")"
    else
        _senha='Null'
    fi
    suser=$(echo -e "\033[1;31m[\033[1;36m$i_display\033[1;31m] \033[1;37m- \033[1;32m$_user\033[0m")
    ssenha=$(echo -e "\033[1;33mContraseña\033[1;37m: $_senha")
    printf '%-60s%s\n' "$suser" "$ssenha"
    _userPass+=$'\n'"${i_display}:${_user}"
done <<< "$_userT"

echo ""
echo -ne "\033[1;32mNúmero o nombre de usuario:\033[1;37m "
read -r option
[[ -z "$option" ]] && exit 1

if [[ "$option" =~ ^[0-9]+$ ]]; then
    user=$(printf '%s\n' "$_userPass" | grep -E "^0*${option}:" | head -1 | cut -d: -f2)
else
    user="$option"
fi

if [[ -z "$user" ]] || ! redlibre_rev_owned "$user"; then
    echo -e "\n\033[1;31mSelección inválida.\033[0m\n"
    sleep 2
    exit 1
fi

if ! grep -q "/$user:" /etc/passwd 2>/dev/null; then
    echo -e "\n\033[1;31mEl usuario no existe en el sistema.\033[0m\n"
    sleep 2
    exit 1
fi

echo -ne "\n\033[1;32mNueva contraseña para \033[1;33m$user\033[1;37m: "
read -r password
sizepass=${#password}
if [[ $sizepass -lt 4 ]]; then
    echo -e "\n\033[1;31mMínimo 4 caracteres.\033[0m\n"
    exit 1
fi

ps x | grep "$user" | grep -v grep | grep -v pt >/tmp/rem_rev 2>/dev/null
if [[ $(grep -c "$user" /tmp/rem_rev 2>/dev/null) -eq 0 ]]; then
    echo "$user:$password" | chpasswd
else
    echo ""
    echo -e "\033[1;33mUsuario conectado. Desconectando...\033[0m"
    pkill -f "$user" 2>/dev/null
    echo "$user:$password" | chpasswd
fi
echo "$password" > "/etc/RedLibre/senha/$user"
echo -e "\n\033[1;32mContraseña actualizada para $user.\033[0m\n"
sleep 2
exit 0
