#!/bin/bash
#====================================================
# Monitor en línea — solo clientes del revendedor
# Conteo por ps (como infousers); pgrep -u a menudo no ve sesiones sshd.
#====================================================
[[ -f /etc/RedLibre/redlibre-rev-common ]] && . /etc/RedLibre/redlibre-rev-common || exit 1
if ! declare -F redlibre_rev_is_managed_vpn_user >/dev/null 2>&1; then
    redlibre_rev_is_managed_vpn_user() {
        local _u="$1"
        local _uid
        [[ -n "$_u" ]] || return 1
        _uid=$(id -u "$_u" 2>/dev/null) || return 1
        [[ "$_uid" -ge 1000 ]] || return 1
        return 0
    }
fi
redlibre_rev_init

database="/root/usuarios.db"

_rev_list=$(redlibre_rev_list_owned)
if [[ -z "${_rev_list//[[:space:]]/}" ]]; then
    clear
    echo -e "\E[44;1;37m Usuario        Estado        Conexión        Tiempo   \E[0m"
    echo ""
    echo -e "\033[1;33m  No tiene usuarios registrados en su cartera.\033[0m"
    echo ""
    echo -ne "\033[1;33mPresione [ENTER] para volver...\033[0m"
    read -r
    exit 0
fi

clear
echo -e "\E[44;1;37m Usuario        Estado        Conexión        Tiempo   \E[0m"
echo ""

TOTAL_SESSIONS=0

while IFS= read -r user_orig; do
    [[ -z "$user_orig" ]] && continue
    user="${user_orig//[[:space:]]/}"
    redlibre_rev_owned "$user" || continue
    id "$user" &>/dev/null || continue
    redlibre_rev_is_managed_vpn_user "$user" || continue

    limit=$(awk -v u="$user" '$1 == u { print $2; exit }' "$database" 2>/dev/null)
    limit="${limit//[[:space:]]/}"
    [[ -z "$limit" || ! "$limit" =~ ^[0-9]+$ ]] && limit=1

    session_count=$(ps -u "$user" 2>/dev/null | grep -c sshd || true)
    session_count="${session_count//[^0-9]/}"
    [[ -z "$session_count" ]] && session_count=0

    if [[ "$session_count" -eq 0 ]]; then
        status=$(echo -e "\033[1;31mOffline \033[1;33m       ")
        timerr="00:00:00"
    else
        TOTAL_SESSIONS=$((TOTAL_SESSIONS + session_count))
        oldest_pid=""
        while read -r _pid _com; do
            [[ "$_com" == *sshd* ]] || continue
            [[ -n "$_pid" ]] || continue
            if [[ -z "$oldest_pid" ]] || [[ "$_pid" -lt "$oldest_pid" ]]; then
                oldest_pid="$_pid"
            fi
        done < <(ps -u "$user" -o pid= -o comm= 2>/dev/null)

        timerr="00:00:00"
        if [[ -n "$oldest_pid" ]]; then
            timerr=$(ps -o etime= -p "$oldest_pid" 2>/dev/null | tr -d '[:space:]')
        fi
        [[ -z "$timerr" ]] && timerr="00:00:00"
        status=$(echo -e "\033[1;32mOnline\033[1;33m         ")
    fi

    echo -ne "\033[1;33m"
    printf '%-17s%-14s%-10s%s\n' " $user" "$status" "$session_count/$limit" "$timerr"
    echo -e "\033[0;34m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
done < <(redlibre_rev_list_owned)

echo -e "\n\E[44;1;37m Sesiones Totales Activas: $TOTAL_SESSIONS \E[0m\n"
echo -ne "\033[1;33mPresione [ENTER] para volver...\033[0m"
read -r

exit 0
